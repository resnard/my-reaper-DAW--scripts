        temp_renames = 0,    -- increments when a plugin is renamed
        folder_tree = 0,     -- increments when folders are refreshed
    },
}

-- ======================================================================
-- Formatting helpers
-- ======================================================================
local function format_pin_display(config)
    if not config then return "Global" end
    if config.mode then
        local in_text, out_text = get_global_pin_text(config.mode, settings.pin_preset)
        return string.format("%s → %s", in_text, out_text)
    else
        local in_text = pair_text(config.inL, config.inR)
        local out_text = pair_text(config.outL, config.outR)
        return string.format("%s → %s", in_text, out_text)
    end
end

local function get_item_pin_config(item)
    if item.mode then
        return item.mode, nil
    elseif item.pin then
        return "Custom", item.pin
    else
        local nt = notes_tags[item.name]
        if nt and nt.pin then
            if nt.pin.mode then
                return nt.pin.mode, nil
            else
                return "Custom", nt.pin
            end
        end
    end
    return nil, nil
end

-- ======================================================================
-- Selection helpers
-- ======================================================================
local function select_plugin(name, idx, filtered, mods)
    local ctrl = (mods & r.ImGui_Mod_Ctrl()) ~= 0
    local shift = (mods & r.ImGui_Mod_Shift()) ~= 0
    if ctrl then
        if state.selected_plugins[name] then
            state.selected_plugins[name] = nil
        else
            state.selected_plugins[name] = true
        end
    elseif shift and state.last_clicked_index then
        local start_i = math.min(state.last_clicked_index, idx)
        local end_i = math.max(state.last_clicked_index, idx)
        state.selected_plugins = {}
        for j = start_i, end_i do
            state.selected_plugins[filtered[j].name] = true
        end
    else
        state.selected_plugins = { [name] = true }
        state.last_clicked_index = idx
    end
end

local function select_chain_item(idx, mods)
    local ctrl = (mods & r.ImGui_Mod_Ctrl()) ~= 0
    local shift = (mods & r.ImGui_Mod_Shift()) ~= 0
    if ctrl then
        if state.chain_selected_set[idx] then
            state.chain_selected_set[idx] = nil
        else
            state.chain_selected_set[idx] = true
        end
    elseif shift and state.last_chain_selected_idx then
        local start_i = math.min(state.last_chain_selected_idx, idx)
        local end_i = math.max(state.last_chain_selected_idx, idx)
        state.chain_selected_set = {}
        for i = start_i, end_i do
            state.chain_selected_set[i] = true
        end
    else
        state.chain_selected_set = { [idx] = true }
        state.last_chain_selected_idx = idx
    end
end

-- ======================================================================
-- Folder / tag lookup helpers
-- ======================================================================
local folder_tree = parse_fx_folders()
local function get_clean_name(p)
    if state.temp_renames[p.name] then
        return state.temp_renames[p.name]
    end
    local name = p and p.name or ""
    name = name:gsub("^%s*[^:]+:%s*", "")
    name = name:gsub("%s*%([^)]*%)$", "")
    return name
end
-- Precompute lowercase names for all plugins in each folder
local function precompute_lowercase_names()
    for _, folder in ipairs(folder_tree) do
        for _, plugin in ipairs(folder.plugins) do
            plugin.lower_display = get_clean_name(plugin):lower()
        end
    end
end
precompute_lowercase_names()

if #folder_tree == 0 then
    r.ShowMessageBox("No folders found. Please create custom folders in REAPER's FX browser.", "Info", 0)
end
if #folder_tree > 0 and not settings.go_to_folder_id then
    settings.go_to_folder_id = folder_tree[1].guid
end
state.selected_folder_guid = settings.go_to_folder_id

local function find_folder_node(guid)
    for i = 1, #folder_tree do
        if folder_tree[i].guid == guid then return folder_tree[i] end
    end
    return nil
end

local function get_target_name(target_type)
    if target_type == 0 then
        local track = r.GetSelectedTrack(0, 0)
        if not track then
            return "No track selected (new track will be created)"
        end
        local _, name = r.GetSetMediaTrackInfo_String(track, "P_NAME", "", false)
        if name and name ~= "" then
            return "Selected: " .. name
        else
            local track_num = r.GetMediaTrackInfo_Value(track, "IP_TRACKNUMBER")
            return "Selected: Track " .. tostring(math.tointeger(track_num))
        end
    else
        local item = r.GetSelectedMediaItem(0, 0)
        if not item then
            return "No item selected (fallback to track)"
        end
        local take = r.GetActiveTake(item)
        if not take then
            return "No active take (fallback to track)"
        end
        local name = r.GetTakeName(take)
        if name and name ~= "" then
            return "Selected: " .. name
        else
            return "Selected: (unnamed)"
        end
    end
end

local function get_folder_plugins(guid)
    local node = find_folder_node(guid)
    return node and node.plugins or {}
end

local function get_tags_in_folder(guid)
    local plugins = get_folder_plugins(guid)
    local tags = {}
    for _, p in ipairs(plugins) do
        local nt = notes_tags[p.name]
        if nt and nt.tags then
            for _, tag in ipairs(nt.tags) do
                tags[tag] = true
            end
        end
    end
    local sorted = {}
    for tag in pairs(tags) do sorted[#sorted + 1] = tag end
    table.sort(sorted)
    return sorted
end


local function tag_filter_hash()
    local keys = {}
    for tag in pairs(state.tag_filter) do
        keys[#keys + 1] = tag
    end
    table.sort(keys)
    return table.concat(keys, ",")
end

local function invalidate_plugin_cache()
    state.plugin_cache.valid = false
end

-- Call these whenever underlying data changes
local function bump_notes_tags_version()
    state.data_versions.notes_tags = state.data_versions.notes_tags + 1
    invalidate_plugin_cache()
end

local function bump_temp_renames_version()
    state.data_versions.temp_renames = state.data_versions.temp_renames + 1
    invalidate_plugin_cache()
end

local function bump_folder_tree_version()
    state.data_versions.folder_tree = state.data_versions.folder_tree + 1
    invalidate_plugin_cache()
end


-- ======================================================================
-- Pin routing helpers (unchanged, keep as in original)
-- ======================================================================
local function find_unused_stereo_pair(target, start_ch, is_take)
    start_ch = start_ch or 3
    local used = {}
    local fx_count = is_take and r.TakeFX_GetCount(target) or r.TrackFX_GetCount(target)
    for fx = 0, fx_count - 1 do
        local _, in_cnt, out_cnt
        if is_take then
            _, in_cnt, out_cnt = r.TakeFX_GetIOSize(target, fx)
        else
            _, in_cnt, out_cnt = r.TrackFX_GetIOSize(target, fx)
        end
        for pin = 0, in_cnt - 1 do
            local low, high
            if is_take then
                low, high = r.TakeFX_GetPinMappings(target, fx, 0, pin)
            else
                low, high = r.TrackFX_GetPinMappings(target, fx, 0, pin)
            end
            for ch = 0, 31 do if (low & (1 << ch)) ~= 0 then used[ch + 1] = true end end
            for ch = 32, 63 do if (high & (1 << (ch - 32))) ~= 0 then used[ch + 1] = true end end
        end
        for pin = 0, out_cnt - 1 do
            local low, high
            if is_take then
                low, high = r.TakeFX_GetPinMappings(target, fx, 1, pin)
            else
                low, high = r.TrackFX_GetPinMappings(target, fx, 1, pin)
            end
            for ch = 0, 31 do if (low & (1 << ch)) ~= 0 then used[ch + 1] = true end end
            for ch = 32, 63 do if (high & (1 << (ch - 32))) ~= 0 then used[ch + 1] = true end end
        end
    end
    for pair = start_ch, 63, 2 do
        if not used[pair] and not used[pair+1] then
            return pair, pair+1
        end
    end
    return nil, nil
end

local function resolve_mode_channels(mode, custom, side)
    if mode == "Default" then return 1, 2
    elseif mode == "SC→SC" then return nil, nil
    elseif mode == "In→SC" then
        if side == 0 then return 1, 2 else return nil, nil end
    elseif mode == "SC→Out" then
        if side == 0 then return nil, nil else return 1, 2 end
    elseif mode == "In→Left" then
        if side == 0 then return 1, 2 else return 1, 1 end
    elseif mode == "In→Right" then
        if side == 0 then return 1, 2 else return 2, 2 end
    elseif mode == "SC→Left" then
        if side == 0 then return nil, nil else return 1, 1 end
    elseif mode == "SC→Right" then
        if side == 0 then return nil, nil else return 2, 2 end
    elseif mode == "Left→Out" then
        if side == 0 then return 1, 1 else return 1, 2 end
    elseif mode == "Right→Out" then
        if side == 0 then return 2, 2 else return 1, 2 end
    elseif mode == "Left→SC" then
        if side == 0 then return 1, 1 else return nil, nil end
    elseif mode == "Right→SC" then
        if side == 0 then return 2, 2 else return nil, nil end
    elseif mode == "Custom" then
        if side == 0 then return custom.inL, custom.inR else return custom.outL, custom.outR end
    end
    return 1, 2
end

local function apply_pin_config(target, fx_index, mode, custom, bypass_confirmation, work, is_take)
    if not target or fx_index < 0 then return true end
    if custom and custom.mode then
        mode = custom.mode
        custom = nil
    end
    local inL, inR, outL, outR
    if work then
        inL, inR = work.inL, work.inR
        outL, outR = work.outL, work.outR
    else
        inL, inR = resolve_mode_channels(mode, custom, 0)
        outL, outR = resolve_mode_channels(mode, custom, 1)
        local need_input = (inL == nil)
        local need_output = (outL == nil)
        if need_input or need_output then
            local used_input = {}
            local used_output = {}
            local fx_count = is_take and r.TakeFX_GetCount(target) or r.TrackFX_GetCount(target)
            for fx = 0, fx_count - 1 do
                local _, in_cnt, out_cnt
                if is_take then
                    _, in_cnt, out_cnt = r.TakeFX_GetIOSize(target, fx)
                else
                    _, in_cnt, out_cnt = r.TrackFX_GetIOSize(target, fx)
                end
                for pin = 0, in_cnt - 1 do
                    local low, high
                    if is_take then
                        low, high = r.TakeFX_GetPinMappings(target, fx, 0, pin)
                    else
                        low, high = r.TrackFX_GetPinMappings(target, fx, 0, pin)
                    end
                    for ch = 0, 31 do if (low & (1 << ch)) ~= 0 then used_input[ch + 1] = true end end
                    for ch = 32, 63 do if (high & (1 << (ch - 32))) ~= 0 then used_input[ch + 1] = true end end
                end
                for pin = 0, out_cnt - 1 do
                    local low, high
                    if is_take then
                        low, high = r.TakeFX_GetPinMappings(target, fx, 1, pin)
                    else
                        low, high = r.TrackFX_GetPinMappings(target, fx, 1, pin)
                    end
                    for ch = 0, 31 do if (low & (1 << ch)) ~= 0 then used_output[ch + 1] = true end end
                    for ch = 32, 63 do if (high & (1 << (ch - 32))) ~= 0 then used_output[ch + 1] = true end end
                end
            end
            local function find_free_pair(start, used_table)
                for pair = start, 63, 2 do
                    if not used_table[pair] and not used_table[pair+1] then
                        return pair, pair+1
                    end
                end
                return nil, nil
            end
            if need_input then
                local pairL, pairR = find_free_pair(3, used_input)
                if not pairL then
                    return false, "No unused stereo pair available for SC input (all channels 3-64 are occupied as inputs)."
                end
                inL, inR = pairL, pairR
            end
            if need_output then
                local pairL, pairR = find_free_pair(3, used_output)
                if not pairL then
                    return false, "No unused stereo pair available for SC output (all channels 3-64 are occupied as outputs)."
                end
                outL, outR = pairL, pairR
            end
        end
    end
    local work_tbl = { inL = inL, inR = inR, outL = outL, outR = outR }
    local needed = math.max(work_tbl.inL, work_tbl.inR, work_tbl.outL, work_tbl.outR, 2)
    if not is_take then
        local current_channels = r.GetMediaTrackInfo_Value(target, "I_NCHAN")
        if needed > current_channels and not bypass_confirmation then
            return false, string.format("Track has %d channels, but need %d. Increase track channels?", current_channels, needed)
        end
        if needed > current_channels then
            r.SetMediaTrackInfo_Value(target, "I_NCHAN", needed)
        end
    else
        local current_channels = r.GetMediaItemTakeInfo_Value(target, "I_TAKEFX_NCH")
        if needed > current_channels and not bypass_confirmation then
            return false, string.format("Take has %d channels, but need %d. Increase take channels?", current_channels, needed)
        end
        if needed > current_channels then
            r.SetMediaItemTakeInfo_Value(target, "I_TAKEFX_NCH", needed)
        end
    end
    local function set_pin_mapping(is_out, pin, track_ch)
        if not track_ch then return end
        local pin_zero = pin
        local ch_zero = track_ch - 1
        local low, high = 0, 0
        if ch_zero < 32 then low = 1 << ch_zero else high = 1 << (ch_zero - 32) end
        if is_take then
            r.TakeFX_SetPinMappings(target, fx_index, is_out, pin_zero, low, high)
        else
            r.TrackFX_SetPinMappings(target, fx_index, is_out, pin_zero, low, high)
        end
    end
    set_pin_mapping(0, 0, work_tbl.inL)
    set_pin_mapping(0, 1, work_tbl.inR)
    set_pin_mapping(1, 0, work_tbl.outL)
    set_pin_mapping(1, 1, work_tbl.outR)
    return true
end

-- ======================================================================
-- Simulation helpers
-- ======================================================================
local function simulate_chain_pins(chain, track)
    local used_input = {}
    local used_output = {}
    local fx_count = r.TrackFX_GetCount(track)
    for fx = 0, fx_count - 1 do
        local _, in_cnt, out_cnt = r.TrackFX_GetIOSize(track, fx)
        for pin = 0, in_cnt - 1 do
            local low, high = r.TrackFX_GetPinMappings(track, fx, 0, pin)
            for ch = 0, 31 do if (low & (1 << ch)) ~= 0 then used_input[ch + 1] = true end end
            for ch = 32, 63 do if (high & (1 << (ch - 32))) ~= 0 then used_input[ch + 1] = true end end
        end
        for pin = 0, out_cnt - 1 do
            local low, high = r.TrackFX_GetPinMappings(track, fx, 1, pin)
            for ch = 0, 31 do if (low & (1 << ch)) ~= 0 then used_output[ch + 1] = true end end
            for ch = 32, 63 do if (high & (1 << (ch - 32))) ~= 0 then used_output[ch + 1] = true end end
        end
    end
    local work_list = {}
    local max_needed = 0
    for _, item in ipairs(chain) do
        local inL, inR, outL, outR
        if item.pin then
            inL, inR = item.pin.inL, item.pin.inR
            outL, outR = item.pin.outL, item.pin.outR
        else
            local mode = item.mode or settings.pin_mode
            local function get_side_channels(side)
                if mode == "Default" then return 1, 2
                elseif mode == "SC→SC" then return nil, nil
                elseif mode == "In→SC" then
                    if side == 0 then return 1, 2 else return nil, nil end
                elseif mode == "SC→Out" then
                    if side == 0 then return nil, nil else return 1, 2 end
                elseif mode == "In→Left" then
                    if side == 0 then return 1, 2 else return 1, 1 end
                elseif mode == "In→Right" then
                    if side == 0 then return 1, 2 else return 2, 2 end
                elseif mode == "SC→Left" then
                    if side == 0 then return nil, nil else return 1, 1 end
                elseif mode == "SC→Right" then
                    if side == 0 then return nil, nil else return 2, 2 end
                elseif mode == "Left→Out" then
                    if side == 0 then return 1, 1 else return 1, 2 end
                elseif mode == "Right→Out" then
                    if side == 0 then return 2, 2 else return 1, 2 end
                elseif mode == "Left→SC" then
                    if side == 0 then return 1, 1 else return nil, nil end
                elseif mode == "Right→SC" then
                    if side == 0 then return 2, 2 else return nil, nil end
                else return 1, 2 end
            end
            inL, inR = get_side_channels(0)
            outL, outR = get_side_channels(1)
            local function find_free_pair(start, used_table)
                for pair = start, 63, 2 do
                    if not used_table[pair] and not used_table[pair+1] then
                        return pair, pair+1
                    end
                end
                return nil, nil
            end
            local need_input = (inL == nil)
            local need_output = (outL == nil)
            if need_input then
                local pairL, pairR = find_free_pair(3, used_input)
                if not pairL then return nil, nil, "No unused stereo pair available for SC input" end
                inL, inR = pairL, pairR
                used_input[pairL] = true; used_input[pairR] = true
            end
            if need_output then
                local pairL, pairR = find_free_pair(3, used_output)
                if not pairL then return nil, nil, "No unused stereo pair available for SC output" end
                outL, outR = pairL, pairR
                used_output[pairL] = true; used_output[pairR] = true
            end
        end
        work_list[#work_list + 1] = { inL = inL, inR = inR, outL = outL, outR = outR }
        max_needed = math.max(max_needed, inL, inR, outL, outR, 2)
        used_input[inL] = true; used_input[inR] = true
        used_output[outL] = true; used_output[outR] = true
    end
    return max_needed, work_list, nil
end

local function simulate_chain_max_channels(chain)
    local dummy_track_idx = r.CountTracks(0)
    r.InsertTrackAtIndex(dummy_track_idx, true)
    local dummy_track = r.GetTrack(0, dummy_track_idx)
    if not dummy_track then return 2 end
    local max_needed, _, _ = simulate_chain_pins(chain, dummy_track)
    r.DeleteTrack(dummy_track)
    return math.max(max_needed or 2, 2)
end

-- ======================================================================
-- Insertion queue (unchanged)
-- ======================================================================
local function process_next_pending()
    local p = state.pending_add
    if not p then return end
    if p.index > #p.items then
        if not state.stay_open then state.close_requested = true end
        state.pending_add = nil
        return
    end
    local item = p.items[p.index]
    local tr = p.target_track
    if not tr then
        if p.to_new_track then
            if p.per_track or p.index == 1 then
                r.InsertTrackAtIndex(r.CountTracks(0), true)
                tr = r.GetTrack(0, r.CountTracks(0) - 1)
                r.SetOnlyTrackSelected(tr)
                p.tracks[#p.tracks + 1] = tr
            else
                tr = p.tracks[#p.tracks]
            end
        else
            local sel_tracks = {}
            for i = 0, r.CountSelectedTracks(0) - 1 do
                sel_tracks[#sel_tracks + 1] = r.GetSelectedTrack(0, i)
            end
            if #sel_tracks == 0 then
                r.InsertTrackAtIndex(r.CountTracks(0), true)
                tr = r.GetTrack(0, r.CountTracks(0) - 1)
                r.SetOnlyTrackSelected(tr)
            else
                tr = sel_tracks[1]
            end
        end
    end
    local name = item.name
    local mode = item.mode or settings.pin_mode
    local custom = item.pin or settings.pin_preset
    if item.pin then
        mode = "Custom"
        custom = item.pin
    end
    local is_take = false
    local target = tr
    if p.target_type == 1 then
        local sel_item = r.GetSelectedMediaItem(0, 0)
        if sel_item then
            local take = r.GetActiveTake(sel_item)
            if take then
                target = take
                is_take = true
            end
        end
    end
    local fx_idx
    if is_take then
        fx_idx = r.TakeFX_AddByName(target, name, 1)
    else
        fx_idx = r.TrackFX_AddByName(target, name, false, -1)
    end
    if fx_idx < 0 then
        p.index = p.index + 1
        r.defer(process_next_pending)
        return
    end
    -- Apply rename: chain builder rename first, otherwise the stored display name
    local final_name = item.temp_name or item.display_name
    if final_name then
        if is_take then
            r.TakeFX_SetNamedConfigParm(target, fx_idx, "renamed_name", final_name)
        else
            r.TrackFX_SetNamedConfigParm(target, fx_idx, "renamed_name", final_name)
        end
    end
    local work = nil
    local ok, msg = apply_pin_config(target, fx_idx, mode, custom, p.bypass, work, is_take)
    if ok then
        p.index = p.index + 1
        r.defer(process_next_pending)
    else
        state.confirmation_data = {
            message = msg,
            callback = function(confirmed)
                if confirmed then
                    local ok2 = apply_pin_config(target, fx_idx, mode, custom, true, work, is_take)
                    if ok2 then p.index = p.index + 1 end
                else
                    p.index = p.index + 1
                end
                r.defer(process_next_pending)
            end,
        }
    end
end

-- ======================================================================
-- FX chain file handling
-- ======================================================================
local function read_chain_inner(file_path)
    local function try_open(path)
        local f = io.open(path, "r")
        if f then
            local content = f:read("*a")
            f:close()
            return content
        end
        return nil
    end
    local content = try_open(file_path)
    if not content then
        local lower_path = file_path:gsub("%.RfxChain$", ".rfxchain")
        content = try_open(lower_path)
        if not content and not file_path:match("%.RfxChain$") then
            content = try_open(file_path .. ".RfxChain")
            if not content then
                content = try_open(file_path .. ".rfxchain")
            end
        end
        if not content then
            r.ShowConsoleMsg("Chain file not found: " .. file_path .. "\n")
            return nil
        end
    end
    content = content:gsub("^\xEF\xBB\xBF", "")
    content = content:gsub("\r", "")
    local start_tag = "<FXCHAIN"
    local start_pos = content:find(start_tag)
    if start_pos then
        local lines = {}
        for line in content:gmatch("([^\n]*)\n?") do
            lines[#lines + 1] = line
        end
        local start_idx, end_idx
        for i, line in ipairs(lines) do
            if line:find(start_tag) then start_idx = i end
            if line:match("^%s*>%s*$") then end_idx = i end
        end
        if start_idx and end_idx and start_idx < end_idx then
            local inner_lines = {}
            for i = start_idx + 1, end_idx - 1 do
                inner_lines[#inner_lines + 1] = lines[i]
            end
            return table.concat(inner_lines, "\n")
        end
    end
    return content
end

local function append_fx_chunk(track, chunk)
    local _, track_chunk = r.GetTrackStateChunk(track, "", false)
    local fxchain_start = track_chunk:find("<FXCHAIN")
    if not fxchain_start then
        local last_gt = track_chunk:reverse():find(">") or 0
        if last_gt > 0 then
            local pos = #track_chunk - last_gt + 1
            local new_block = "<FXCHAIN\n" .. chunk .. "\n>\n"
            track_chunk = track_chunk:sub(1, pos-1) .. new_block .. track_chunk:sub(pos)
            r.SetTrackStateChunk(track, track_chunk, false)
            return true
        else
            return false
        end
    end
    local pos = fxchain_start
    local depth = 1
    local last_gt = nil
    while pos <= #track_chunk do
        local next_lt = track_chunk:find("\n<", pos, true)
        local next_gt = track_chunk:find("\n>\n", pos, true)
        if not next_lt and not next_gt then break end
        if next_lt and (not next_gt or next_lt < next_gt) then
            depth = depth + 1
            pos = next_lt + 1
        else
            depth = depth - 1
            pos = next_gt + 1
            if depth == 0 then
                last_gt = next_gt
                break
            end
        end
    end
    if not last_gt then return false end
    local new_chunk = track_chunk:sub(1, last_gt-1) .. "\n" .. chunk .. "\n" .. track_chunk:sub(last_gt)
    r.SetTrackStateChunk(track, new_chunk, false)
    return true
end

-- ======================================================================
-- Insertion functions
-- ======================================================================
local function add_chain_to_track(chain, bypass_confirmation)
    if #chain == 0 then return end
    local target_track = r.GetSelectedTrack(0, 0)
    if not target_track then
        r.InsertTrackAtIndex(r.CountTracks(0), true)
        target_track = r.GetTrack(0, r.CountTracks(0) - 1)
        r.SetOnlyTrackSelected(target_track)
    end
    r.Undo_BeginBlock()
    local temp_track_idx = r.CountTracks(0)
    r.InsertTrackAtIndex(temp_track_idx, true)
    local temp_track = r.GetTrack(0, temp_track_idx)
    if not temp_track then return end
    for _, item in ipairs(chain) do
        if item.is_fxchain and item.chain_path then
            local inner_chunk = read_chain_inner(item.chain_path)
            if inner_chunk then
                append_fx_chunk(temp_track, inner_chunk)
            else
                r.ShowMessageBox("Could not read chain file: " .. item.chain_path, "Error", 0)
            end
        else
            local mode = item.mode or settings.pin_mode
            local custom = item.pin or settings.pin_preset
            local fx_idx = r.TrackFX_AddByName(temp_track, item.name, false, -1)
            if fx_idx >= 0 then
                apply_pin_config(temp_track, fx_idx, mode, custom, true, nil, false)
                local final_name = item.temp_name or state.temp_renames[item.name]
                if final_name then
                    r.TrackFX_SetNamedConfigParm(temp_track, fx_idx, "renamed_name", final_name)
                end
            end
        end
    end
    local current_channels = r.GetMediaTrackInfo_Value(target_track, "I_NCHAN")
    local max_needed = r.GetMediaTrackInfo_Value(temp_track, "I_NCHAN")
    if max_needed < 2 then max_needed = 2 end
    local function insert()
        local _, chunk = r.GetTrackStateChunk(temp_track, "", false)
        local lines = {}
        for line in chunk:gmatch("([^\n]*)\n?") do
            lines[#lines + 1] = line
        end
        local start_idx, end_idx
        for i = 1, #lines do
            if lines[i]:find("<FXCHAIN") then start_idx = i; break end
        end
        for i = #lines, 1, -1 do
            if lines[i]:match("^%s*>%s*$") then end_idx = i; break end
        end
        if not start_idx or not end_idx or start_idx >= end_idx then
            r.ShowMessageBox("Failed to extract FX chain from temporary track.", "Error", 0)
            r.DeleteTrack(temp_track)
            return
        end
        local inner_lines = {}
        for i = start_idx + 1, end_idx - 1 do
            inner_lines[#inner_lines + 1] = lines[i]
        end
        local fxchain = table.concat(inner_lines, "\n")
        append_fx_chunk(target_track, fxchain)
        r.DeleteTrack(temp_track)
        if not state.stay_open then state.close_requested = true end
    end
    if not bypass_confirmation and max_needed > current_channels then
        state.confirmation_data = {
            message = string.format(
                "This chain requires up to %d channels. Track currently has %d. Increase track channels?",
                max_needed, current_channels
            ),
            callback = function(confirmed)
                if confirmed then
                    r.SetMediaTrackInfo_Value(target_track, "I_NCHAN", max_needed)
                    insert()
                else
                    r.DeleteTrack(temp_track)
                end
                r.Undo_EndBlock("Insert FX Chain", -1)
            end,
        }
    else
        insert()
        r.Undo_EndBlock("Insert FX Chain", -1)
    end
end

local function add_plugins_with_configs(items, bypass_confirmation)
    if #items == 0 then return end
    local target_track = r.GetSelectedTrack(0, 0)
    if not target_track then
        r.InsertTrackAtIndex(r.CountTracks(0), true)
        target_track = r.GetTrack(0, r.CountTracks(0) - 1)
        r.SetOnlyTrackSelected(target_track)
    end
    r.Undo_BeginBlock()
    if not bypass_confirmation then
        local max_needed = simulate_chain_max_channels(items)
        local current_channels = r.GetMediaTrackInfo_Value(target_track, "I_NCHAN")
        if max_needed > current_channels then
            state.confirmation_data = {
                message = string.format(
                    "This chain requires up to %d channels. Track currently has %d. Increase track channels?",
                    max_needed, current_channels
                ),
                callback = function(confirmed)
                    if confirmed then
                        r.SetMediaTrackInfo_Value(target_track, "I_NCHAN", max_needed)
                        add_plugins_with_configs(items, true)
                    end
                    r.Undo_EndBlock("Insert Plugin(s)", -1)
                end,
            }
            return
        end
    end
    -- Build queue items, preserving display_name and temp_name
    local queue_items = {}
    for _, item in ipairs(items) do
        table.insert(queue_items, {
            name = item.name,
            display_name = item.display_name,   -- <-- added
            pin = item.pin,
            mode = item.mode,
            temp_name = item.temp_name,
            is_fxchain = false,
        })
    end
    state.pending_add = {
        items = queue_items,
        to_new_track = false,
        per_track = false,
        bypass = bypass_confirmation,
        index = 1,
        tracks = {},
        target_track = target_track,
        target_type = state.insert_target,
    }
    process_next_pending()
    r.Undo_EndBlock("Insert Plugin(s)", -1)
end

local function has_fxchain(chain)
    for _, item in ipairs(chain) do
        if item.is_fxchain then return true end
    end
    return false
end

-- ======================================================================
-- Popup helpers
-- ======================================================================
local focus_input = true
local function center_next_popup()
    local main_x, main_y = r.ImGui_GetWindowPos(ctx)
    local main_w, main_h = r.ImGui_GetWindowSize(ctx)
    local center_x = main_x + main_w * 0.5
    local center_y = main_y + main_h * 0.5
    r.ImGui_SetNextWindowPos(ctx, center_x, center_y, r.ImGui_Cond_Appearing(), 0.5, 0.1)
end

local function focus()
  if focus_input then
      r.ImGui_SetKeyboardFocusHere(ctx)
      focus_input = false
  end
end

local function close_popup(open_flag_field)
reaper.ImGui_CloseCurrentPopup(ctx)
state[open_flag_field] = false
state.popups_opened = state.popups_opened - 1
focus_input = true
end

local function begin_centered_modal(title, open_flag_field)
   -- this will always loop
    if  state[open_flag_field] then
        center_next_popup()
        if open_flag_field == "note_edit_popup_open" then
        r.ImGui_SetNextWindowSize(ctx, 500, 300, r.ImGui_Cond_FirstUseEver())
        r.ImGui_SetNextWindowSizeConstraints(ctx, 450, 200, 10000, 10000)
        elseif open_flag_field == "full_note_popup_open" then
        r.ImGui_SetNextWindowSize(ctx, 500, 300, r.ImGui_Cond_FirstUseEver())
        r.ImGui_SetNextWindowSizeConstraints(ctx, 350, 135, 900, 800)
        end

            r.ImGui_OpenPopup(ctx, title)
              
  --  reaper.ShowConsoleMsg(tostring(state.popups_opened))
     elseif open_flag_field == "confirmation_popup_open" and state.confirmation_data and not state[open_flag_field] then
       state[open_flag_field] = true
           state.popups_opened =   state.popups_opened + 1
        r.ImGui_SetNextWindowSize(ctx, 380, 300)
        r.ImGui_OpenPopup(ctx, title)
    end
 
    local flags 
    if open_flag_field == "full_note_popup_open" then flags = 0 else flags = r.ImGui_WindowFlags_AlwaysAutoResize() end
         
    return r.ImGui_BeginPopupModal(ctx, title, nil, flags)
end

-- ======================================================================
-- Pin mode popups
-- ======================================================================
local function draw_mode_combo(label, current_mode)
    local current_idx = 1
    for i = 1, #MODE_NAMES do
        if MODE_NAMES[i] == current_mode then current_idx = i; break end
    end
    local changed, new_idx = r.ImGui_Combo(ctx, label, current_idx - 1, table.concat(MODE_NAMES, "\0") .. "\0")
    return changed, (new_idx and MODE_NAMES[new_idx + 1] or current_mode)
end

local function apply_mode_preset(mode)
    if MODE_PRESETS[mode] then
        settings.pin_preset = {
            inL = MODE_PRESETS[mode].inL,
            inR = MODE_PRESETS[mode].inR,
            outL = MODE_PRESETS[mode].outL,
            outR = MODE_PRESETS[mode].outR,
        }
    end
end

local function draw_pin_popup()
local popup =  "pin_popup_open"
    if begin_centered_modal("Global Pin Settings", popup) then
        local changed, new_mode = draw_mode_combo("Mode", settings.pin_mode)
        if changed then
            settings.pin_mode = new_mode
            apply_mode_preset(new_mode)
        end
        if settings.pin_mode == "Custom" then
            r.ImGui_Separator(ctx)
            r.ImGui_Text(ctx, "Custom Track Channels:")
            r.ImGui_PushItemWidth(ctx, 60)
            r.ImGui_Text(ctx, "In L"); r.ImGui_SameLine(ctx, 50)
            r.ImGui_Text(ctx, "In R"); r.ImGui_SameLine(ctx, 120)
            r.ImGui_Text(ctx, "Out L"); r.ImGui_SameLine(ctx, 190)
            r.ImGui_Text(ctx, "Out R")
            local changed_val
            changed_val, settings.pin_preset.inL = r.ImGui_DragInt(ctx, "##inL", settings.pin_preset.inL, 1, 1, 64)
            if changed_val then settings.pin_preset.inL = clamp_channel(settings.pin_preset.inL) end
            r.ImGui_SameLine(ctx)
            changed_val, settings.pin_preset.inR = r.ImGui_DragInt(ctx, "##inR", settings.pin_preset.inR, 1, 1, 64)
            if changed_val then settings.pin_preset.inR = clamp_channel(settings.pin_preset.inR) end
            r.ImGui_SameLine(ctx)
            changed_val, settings.pin_preset.outL = r.ImGui_DragInt(ctx, "##outL", settings.pin_preset.outL, 1, 1, 64)
            if changed_val then settings.pin_preset.outL = clamp_channel(settings.pin_preset.outL) end
            r.ImGui_SameLine(ctx)
            changed_val, settings.pin_preset.outR = r.ImGui_DragInt(ctx, "##outR", settings.pin_preset.outR, 1, 1, 64)
            if changed_val then settings.pin_preset.outR = clamp_channel(settings.pin_preset.outR) end
            r.ImGui_PopItemWidth(ctx)
        else
            r.ImGui_Separator(ctx)
            r.ImGui_TextWrapped(ctx, get_mode_description(settings.pin_mode))
        end
        r.ImGui_Separator(ctx)
        if r.ImGui_Button(ctx, "Close") then
          close_popup(popup)
        end
        r.ImGui_EndPopup(ctx)
    end
end

local function draw_custom_pin_popup()
local popup = "custom_pin_popup_open"
    if begin_centered_modal("Custom Pin for " .. (state.editing_plugin_name or ""), popup) then
        local preset_index = 13
        if state.custom_pin_force_custom then
            preset_index = 13
        elseif state.custom_pin_mode then
            for i, name in ipairs(MODE_NAMES) do
                if name == state.custom_pin_mode then
                    preset_index = i
                    break
                end
            end
        else
            local b = state.custom_pin_buffer
            if     b.inL == 1 and b.inR == 2 and b.outL == 1 and b.outR == 2 then preset_index = 1
            elseif b.inL == 3 and b.inR == 4 and b.outL == 3 and b.outR == 4 then preset_index = 2
            elseif b.inL == 1 and b.inR == 2 and b.outL == 3 and b.outR == 4 then preset_index = 3
            elseif b.inL == 3 and b.inR == 4 and b.outL == 1 and b.outR == 2 then preset_index = 4
            elseif b.inL == 1 and b.inR == 2 and b.outL == 1 and b.outR == 1 then preset_index = 5
            elseif b.inL == 1 and b.inR == 2 and b.outL == 2 and b.outR == 2 then preset_index = 6
            elseif b.inL == 3 and b.inR == 4 and b.outL == 1 and b.outR == 1 then preset_index = 7
            elseif b.inL == 3 and b.inR == 4 and b.outL == 2 and b.outR == 2 then preset_index = 8
            elseif b.inL == 1 and b.inR == 1 and b.outL == 1 and b.outR == 2 then preset_index = 9
            elseif b.inL == 2 and b.inR == 2 and b.outL == 1 and b.outR == 2 then preset_index = 10
            elseif b.inL == 1 and b.inR == 1 and b.outL == 3 and b.outR == 4 then preset_index = 11
            elseif b.inL == 2 and b.inR == 2 and b.outL == 3 and b.outR == 4 then preset_index = 12
            else preset_index = 13 end
        end
        local changed, new_idx = r.ImGui_Combo(ctx, "Preset", preset_index - 1, table.concat(MODE_NAMES, "\0") .. "\0")
        if changed then
            local selected = new_idx + 1
            if selected == 13 then
                state.custom_pin_force_custom = true
                state.custom_pin_mode = nil
            else
                state.custom_pin_force_custom = false
                state.custom_pin_mode = MODE_NAMES[selected]
                state.custom_pin_buffer = get_mode_preset(state.custom_pin_mode)
            end
        end
        if (preset_index == 13 or state.custom_pin_force_custom) then
            r.ImGui_Separator(ctx)
            r.ImGui_Text(ctx, "Manual Track Channels:")
            r.ImGui_PushItemWidth(ctx, 60)
            r.ImGui_Text(ctx, "In L"); r.ImGui_SameLine(ctx, 50)
            r.ImGui_Text(ctx, "In R"); r.ImGui_SameLine(ctx, 120)
            r.ImGui_Text(ctx, "Out L"); r.ImGui_SameLine(ctx, 190)
            r.ImGui_Text(ctx, "Out R")
            local changed_val
            changed_val, state.custom_pin_buffer.inL = r.ImGui_DragInt(ctx, "##pin_inL", state.custom_pin_buffer.inL, 1, 1, 64)
            if changed_val then state.custom_pin_buffer.inL = clamp_channel(state.custom_pin_buffer.inL) end
            r.ImGui_SameLine(ctx)
            changed_val, state.custom_pin_buffer.inR = r.ImGui_DragInt(ctx, "##pin_inR", state.custom_pin_buffer.inR, 1, 1, 64)
            if changed_val then state.custom_pin_buffer.inR = clamp_channel(state.custom_pin_buffer.inR) end
            r.ImGui_SameLine(ctx)
            changed_val, state.custom_pin_buffer.outL = r.ImGui_DragInt(ctx, "##pin_outL", state.custom_pin_buffer.outL, 1, 1, 64)
            if changed_val then state.custom_pin_buffer.outL = clamp_channel(state.custom_pin_buffer.outL) end
            r.ImGui_SameLine(ctx)
            changed_val, state.custom_pin_buffer.outR = r.ImGui_DragInt(ctx, "##pin_outR", state.custom_pin_buffer.outR, 1, 1, 64)
            if changed_val then state.custom_pin_buffer.outR = clamp_channel(state.custom_pin_buffer.outR) end
            r.ImGui_PopItemWidth(ctx)
        else
            r.ImGui_Separator(ctx)
            r.ImGui_TextWrapped(ctx, get_mode_description(MODE_NAMES[preset_index]))
        end
        r.ImGui_Separator(ctx)
        if r.ImGui_Button(ctx, "Save") then
            if state.editing_plugin_name then
                if state.editing_chain_idx ~= nil then
                    local chain_idx = state.editing_chain_idx + 1
                    if state.chain_plugins[chain_idx] then
                        if (preset_index == 13 or state.custom_pin_force_custom) then
                            state.chain_plugins[chain_idx].pin = {
                                inL = state.custom_pin_buffer.inL,
                                inR = state.custom_pin_buffer.inR,
                                outL = state.custom_pin_buffer.outL,
                                outR = state.custom_pin_buffer.outR
                            }
                            state.chain_plugins[chain_idx].mode = nil
                        else
                            state.chain_plugins[chain_idx].mode = MODE_NAMES[preset_index]
                            state.chain_plugins[chain_idx].pin = nil
                        end
                    end
                else
                    notes_tags[state.editing_plugin_name] = notes_tags[state.editing_plugin_name] or {}
                    if (preset_index == 13 or state.custom_pin_force_custom) then
                        notes_tags[state.editing_plugin_name].pin = {
                            inL = state.custom_pin_buffer.inL,
                            inR = state.custom_pin_buffer.inR,
                            outL = state.custom_pin_buffer.outL,
                            outR = state.custom_pin_buffer.outR,
                        }
                    else
                        notes_tags[state.editing_plugin_name].pin = {
                            mode = MODE_NAMES[preset_index],
                        }
                    end
                    save_table(NOTES_TAGS_FILE, notes_tags)
                end
            end
         close_popup(popup)
        end
        r.ImGui_SameLine(ctx)
        if r.ImGui_Button(ctx, "Reset to Global") then
            if state.editing_plugin_name then
                if state.editing_chain_idx ~= nil then
                    local chain_idx = state.editing_chain_idx + 1
                    if state.chain_plugins[chain_idx] then
                        state.chain_plugins[chain_idx].pin = nil
                        state.chain_plugins[chain_idx].mode = nil
                    end
                else
                    if notes_tags[state.editing_plugin_name] then
                        notes_tags[state.editing_plugin_name].pin = nil
                        save_table(NOTES_TAGS_FILE, notes_tags)
                    end
                end
            end
           close_popup(popup)
        end
        r.ImGui_SameLine(ctx)
        if r.ImGui_Button(ctx, "Cancel") then
            state.editing_chain_idx = nil
           close_popup(popup)
        end
        r.ImGui_EndPopup(ctx)
    end
end

