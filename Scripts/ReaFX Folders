-- ======================================================================
-- Confirmation popup (separate)
-- ======================================================================
local function draw_confirmation_popup()
     
    local popup = "confirmation_popup_open"
    if begin_centered_modal("Confirm Channel Increase", popup) then
        r.ImGui_TextWrapped(ctx, state.confirmation_data and state.confirmation_data.message or "")
        if r.ImGui_Button(ctx, "Yes") then
            local data = state.confirmation_data
            state.confirmation_data = nil
           
            if data then data.callback(true) end
            close_popup(popup)
        end
        r.ImGui_SameLine(ctx)
        if r.ImGui_Button(ctx, "No") then
            local data = state.confirmation_data
            state.confirmation_data = nil
            if data then data.callback(false) end
            close_popup(popup)
        end
        r.ImGui_EndPopup(ctx)
    elseif not state.confirmation_data then
        state.confirmation_popup_open = false
    end
end

-- ======================================================================
-- Note link parsing
-- ======================================================================
local function get_note_segments(note_text)
    if not note_text or note_text == "" then return {} end
    local segments = {}
    local pattern = "<link%s+([^%s@]+)%s+@([^>]+)>"
    local file_pattern = "<file%s+([^%s@]+)%s+@([^>]+)>"
    local pos = 1
    while true do
        local start_link, end_link, link_url, link_placeholder = note_text:find(pattern, pos)
        local start_file, end_file, file_url, file_placeholder = note_text:find(file_pattern, pos)
        local start_idx, end_idx, url, placeholder, is_file = nil, nil, nil, nil, false
        if start_link and (not start_file or start_link < start_file) then
            start_idx, end_idx, url, placeholder = start_link, end_link, link_url, link_placeholder
            is_file = false
        elseif start_file then
            start_idx, end_idx, url, placeholder = start_file, end_file, file_url, file_placeholder
            is_file = true
        else
            break
        end
        if start_idx > pos then
            segments[#segments + 1] = { type = "text", text = note_text:sub(pos, start_idx-1) }
        end
        if is_file then
            segments[#segments + 1] = { type = "file", url = url, placeholder = placeholder }
        else
            segments[#segments + 1] = { type = "link", url = url, placeholder = placeholder }
        end
        pos = end_idx + 1
    end
    if pos <= #note_text then
        segments[#segments + 1] = { type = "text", text = note_text:sub(pos) }
    end
    return segments
end

local function note_to_display_string(note_text)
    if not note_text or note_text == "" then return "" end
    local display = note_text
    display = display:gsub("<link%s+[^%s@]+%s+@([^>]+)>", "%1")
    display = display:gsub("<file%s+[^%s@]+%s+@([^>]+)>", "%1")
    return display
end

local function draw_full_note_popup()
   local popup = "full_note_popup_open"

    if begin_centered_modal("Full Note for " .. state.full_note_plugin, popup) then
        if r.ImGui_BeginChild(ctx, "note_scroll", 0, -r.ImGui_GetTextLineHeightWithSpacing(ctx) - 10, 0, 0) then
            local segments = get_note_segments(state.full_note_text)
            local first = true
            for _, seg in ipairs(segments) do
                if seg.type == "text" then
                    if not first then r.ImGui_SameLine(ctx) end
                    r.ImGui_TextWrapped(ctx, seg.text)
                    first = false
                else
                    if seg.type == "link" then
                        local target = seg.url
                        if not target:match("^https?://") then
                            target = "http://" .. target
                        end
                        if not first then r.ImGui_SameLine(ctx) end
                        r.ImGui_TextLinkOpenURL(ctx, seg.placeholder, target)
                        if r.ImGui_IsItemHovered(ctx) then
                            r.ImGui_SetTooltip(ctx, target)
                        end
                        first = false
                    else -- file
                        local raw_path = seg.url:gsub('^["\']', ''):gsub('["\']$', '')
                        local target = raw_path:gsub("\\", "/")
                        if not target:match("^file://") then
                            target = "file:///" .. target
                        end
                        if not first then r.ImGui_SameLine(ctx) end
                        r.ImGui_TextLinkOpenURL(ctx, seg.placeholder, target)
                        if r.ImGui_IsItemHovered(ctx) then
                            local cleaned = raw_path:gsub('^["\']', ''):gsub('["\']$', '')
                            local filename = cleaned:match("[^\\/]+$") or seg.placeholder
                            r.ImGui_SetTooltip(ctx, filename)
                        end
                        first = false
                    end
                end
            end
            r.ImGui_EndChild(ctx)
        end
        r.ImGui_Spacing(ctx)
        if r.ImGui_Button(ctx, "Close") then
          close_popup(popup)
        end
        r.ImGui_EndPopup(ctx)
    else
        state.full_note_popup_open = false
    end
end

-- ======================================================================
-- Chain builder helpers
-- ======================================================================
local function build_chain_from_selection()
    local plugins_in_order = {}
    local selected_set = state.selected_plugins
    local plugins = state.selected_folder_guid and get_folder_plugins(state.selected_folder_guid) or {}
    local query = state.column3_search:lower()
    local filtered_plugins = {}
    for _, p in ipairs(plugins) do
        local display_name = get_clean_name(p)
        if query == "" or plain_find(display_name:lower(), query) or plain_find((p.name or ""):lower(), query) then
            filtered_plugins[#filtered_plugins + 1] = p
        end
    end
    for _, p in ipairs(filtered_plugins) do
        if selected_set[p.name] then
            local pin = nil
            local mode = nil
            local nt = notes_tags[p.name]
            if nt and nt.pin then
                if nt.pin.mode then
                    mode = nt.pin.mode
                else
                    pin = {
                        inL = nt.pin.inL,
                        inR = nt.pin.inR,
                        outL = nt.pin.outL,
                        outR = nt.pin.outR,
                    }
                end
            end
            local chain_item = {
                name = p.name,
                display_name = get_clean_name(p),
                pin = pin,
                mode = mode,
                temp_name = state.temp_renames[p.name],
            }
            if p.is_fxchain and p.chain_path then
                chain_item.is_fxchain = true
                chain_item.chain_path = p.chain_path
            end
            table.insert(plugins_in_order, chain_item)
        end
    end
    return plugins_in_order
end

local function add_to_chain(plugins)
    for _, p in ipairs(plugins) do
        state.chain_plugins[#state.chain_plugins + 1] = p
    end
end

-- ======================================================================
-- Chain manipulation helpers
-- ======================================================================
local function get_sorted_selected_chain_indices()
    local indices = {}
    for idx in pairs(state.chain_selected_set) do
        indices[#indices + 1] = idx
    end
    table.sort(indices)
    return indices
end

local function adjust_selection_for_move(old_idx, new_idx)
    if old_idx == new_idx then return end
    local delta = new_idx > old_idx and -1 or 1
    local start, stop = math.min(old_idx, new_idx), math.max(old_idx, new_idx)
    local new_selection = {}
    for idx in pairs(state.chain_selected_set) do
        if idx == old_idx then
            new_selection[new_idx] = true
        elseif idx >= start and idx <= stop and idx ~= old_idx then
            new_selection[idx + delta] = true
        else
            new_selection[idx] = true
        end
    end
    state.chain_selected_set = new_selection
    if state.last_chain_selected_idx then
        local last = state.last_chain_selected_idx
        if last == old_idx then
            state.last_chain_selected_idx = new_idx
        elseif last >= start and last <= stop and last ~= old_idx then
            state.last_chain_selected_idx = last + delta
        end
    end
end

local function move_selected_chain_items(delta)
    local indices = get_sorted_selected_chain_indices()
    if #indices == 0 then return end
    if delta < 0 and indices[1] == 1 then return end
    if delta > 0 and indices[#indices] == #state.chain_plugins then return end
    local selected_items = {}
    for _, idx in ipairs(indices) do
        selected_items[#selected_items + 1] = state.chain_plugins[idx]
    end
    for i = #indices, 1, -1 do
        table.remove(state.chain_plugins, indices[i])
    end
    local new_base = indices[1] + delta
    for i, item in ipairs(selected_items) do
        table.insert(state.chain_plugins, new_base + i - 1, item)
    end
    state.chain_selected_set = {}
    for i = 1, #selected_items do
        state.chain_selected_set[new_base + i - 1] = true
    end
end

local function remove_selected_chain_items()
    local indices = get_sorted_selected_chain_indices()
    for i = #indices, 1, -1 do
        table.remove(state.chain_plugins, indices[i])
    end
    state.chain_selected_set = {}
    if #state.chain_plugins == 0 then
        state.current_view = "plugins"
    end
end

local function reset_selected_chain_pins()
    for idx in pairs(state.chain_selected_set) do
        if state.chain_plugins[idx] then
            state.chain_plugins[idx].pin = nil
            state.chain_plugins[idx].mode = nil
        end
    end
end

local function move_chain_item(idx, delta)  -- idx is 0‑based
    local old_one_based = idx + 1
    local new_one_based = idx + delta + 1
    if new_one_based < 1 or new_one_based > #state.chain_plugins then return end
    local item = state.chain_plugins[old_one_based]
    table.remove(state.chain_plugins, old_one_based)
    table.insert(state.chain_plugins, new_one_based, item)
    adjust_selection_for_move(old_one_based, new_one_based)
end

local function clear_chain()
    state.chain_plugins = {}
    state.current_view = "plugins"
end

local function save_chain_as_fxchain()
    if #state.chain_plugins == 0 then
        r.ShowMessageBox("Chain is empty.", "Save Chain", 0)
        return
    end
    if not r.APIExists("JS_Dialog_BrowseForSaveFile") then
        r.ShowMessageBox("js_ReaScriptAPI extension required for saving.", "Missing API", 0)
        return
    end
    local retval, path = r.JS_Dialog_BrowseForSaveFile(
        "Save FX Chain",
        resource_path .. sep .. "FXChains",
        "Chain",
        "RfxChain file (*.RfxChain)\0*.RfxChain\0\0"
    )
    if not retval or path == "" then return end
    if not path:lower():match("%.rfxchain$") then path = path .. ".RfxChain" end
    local track_count = r.CountTracks(0)
    r.InsertTrackAtIndex(track_count, true)
    local tmp_track = r.GetTrack(0, track_count)
    if not tmp_track then return end
    for _, item in ipairs(state.chain_plugins) do
        if item.is_fxchain and item.chain_path then
            local inner_chunk = read_chain_inner(item.chain_path)
            if inner_chunk then
                append_fx_chunk(tmp_track, inner_chunk)
            else
                r.ShowMessageBox("Could not read chain file: " .. item.chain_path, "Error", 0)
            end
        else
            local mode = item.mode or settings.pin_mode
            local custom = item.pin or settings.pin_preset
            local fx_idx = r.TrackFX_AddByName(tmp_track, item.name, false, -1)
            if fx_idx >= 0 then
                apply_pin_config(tmp_track, fx_idx, mode, custom, true)
                local final_name = item.temp_name or state.temp_renames[item.name]
                if final_name then
                    r.TrackFX_SetNamedConfigParm(tmp_track, fx_idx, "renamed_name", final_name)
                end
            end
        end
    end
    local _, chunk = r.GetTrackStateChunk(tmp_track, "", false)
    local lines = {}
    for line in chunk:gmatch("([^\n]*)\n?") do
        lines[#lines + 1] = line
    end
    local start_idx, end_idx
    for i = 1, #lines do
        if lines[i]:find("<FXCHAIN") then start_idx = i; break end
    end
    for i = #lines, 1, -1 do
        if lines[i]:match("^%s*>%s*$") then end_idx = i; break end
    end
    if not start_idx or not end_idx or start_idx >= end_idx then
        r.ShowMessageBox("Could not extract FX chain block.", "Save Chain Error", 0)
        r.DeleteTrack(tmp_track)
        return
    end
    local inner_lines = {}
    for i = start_idx + 1, end_idx - 1 do
        inner_lines[#inner_lines + 1] = lines[i]
    end
    local fxchain = table.concat(inner_lines, "\n")
    local f = io.open(path, "w")
    if f then
        f:write(fxchain)
        f:close()
    else
        r.ShowMessageBox("Could not write file.", "Save Chain Error", 0)
    end
    r.DeleteTrack(tmp_track)
end

