       focus()
        r.ImGui_PushItemWidth(ctx, 255)
        local changed, buf = r.ImGui_InputText(ctx, "##chain_rename_input", state.chain_rename_buffer, 256)
        r.ImGui_TextDisabled(ctx, "This will be applied when you insert the plugin")
        if changed then state.chain_rename_buffer = buf end
        r.ImGui_Spacing(ctx)
        if r.ImGui_Button(ctx, "Save") then
            if state.chain_renaming_idx ~= nil then
                local idx = state.chain_renaming_idx + 1
                if state.chain_plugins[idx] then
                    if state.chain_rename_buffer == "" then
                        state.chain_plugins[idx].temp_name = nil
                    else
                        state.chain_plugins[idx].temp_name = state.chain_rename_buffer
                    end
                end
            end
            state.chain_renaming_idx = nil
            state.chain_rename_buffer = ""
          close_popup(popup)
        end
        r.ImGui_SameLine(ctx)
        if r.ImGui_Button(ctx, "Cancel") then
            state.chain_renaming_idx = nil
            state.chain_rename_buffer = ""
            close_popup(popup)
        end
        r.ImGui_EndPopup(ctx)
    end
end

