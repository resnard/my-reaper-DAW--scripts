-- draw chain list
local function draw_chain_list()
    r.ImGui_Separator(ctx)
    if r.ImGui_Button(ctx, "Insert Chain") then
        local chain = state.chain_plugins
        if #chain > 0 then
            if has_fxchain(chain) then
                add_chain_to_track(chain, false)
            else
                add_plugins_with_configs(chain, false)
            end
        end
    end
    r.ImGui_SetItemTooltip(ctx, "Insert the chain into the selected track (creates new track if none)")
    r.ImGui_SameLine(ctx)
    if r.ImGui_Button(ctx, "Save as FX Chain") then
        save_chain_as_fxchain()
    end
    r.ImGui_SameLine(ctx)
    if r.ImGui_Button(ctx, "Clear Chain") then
        clear_chain()
    end
    r.ImGui_SameLine(ctx)
    if r.ImGui_Button(ctx, "Reset to Global") then
        for _, item in ipairs(state.chain_plugins) do
            item.pin = nil
            item.mode = nil
        end
    end
    r.ImGui_SetItemTooltip(ctx, "Reset all chain items to global pin configuration")
    r.ImGui_Separator(ctx)
    if #state.chain_plugins == 0 then
        r.ImGui_Text(ctx, "Chain is empty. Select plugins and use 'Create FX Chain from Selected'.")
        return
    end
    local col_flags = r.ImGui_TableFlags_Resizable() | r.ImGui_TableFlags_Borders()
    if r.ImGui_BeginTable(ctx, "chain_table", 3, col_flags) then
        r.ImGui_TableSetupColumn(ctx, "Order", r.ImGui_TableColumnFlags_WidthFixed(), 50)
        r.ImGui_TableSetupColumn(ctx, "Name", r.ImGui_TableColumnFlags_WidthStretch(), 200)
        r.ImGui_TableSetupColumn(ctx, "Pins", r.ImGui_TableColumnFlags_WidthFixed(), 100)
        r.ImGui_TableHeadersRow(ctx)
        for idx, item in ipairs(state.chain_plugins) do
            r.ImGui_TableNextRow(ctx)
            r.ImGui_PushID(ctx, idx)
            r.ImGui_TableSetColumnIndex(ctx, 0)
            local up_enabled = idx > 1
            local down_enabled = idx < #state.chain_plugins
            if up_enabled then
                if r.ImGui_ArrowButton(ctx, "up", r.ImGui_Dir_Up()) then
                    if state.chain_selected_set[idx] then
                        move_selected_chain_items(-1)
                    else
                        move_chain_item(idx - 1, -1)
                    end
                end
                r.ImGui_SameLine(ctx)
            else
                r.ImGui_PushStyleVar(ctx, r.ImGui_StyleVar_Alpha(), 0.5)
                r.ImGui_ArrowButton(ctx, "up_disabled", r.ImGui_Dir_Up())
                r.ImGui_PopStyleVar(ctx)
                r.ImGui_SameLine(ctx)
            end
            if down_enabled then
                if r.ImGui_ArrowButton(ctx, "down", r.ImGui_Dir_Down()) then
                    if state.chain_selected_set[idx] then
                        move_selected_chain_items(1)
                    else
                        move_chain_item(idx - 1, 1)
                    end
                end
            else
                r.ImGui_PushStyleVar(ctx, r.ImGui_StyleVar_Alpha(), 0.5)
                r.ImGui_ArrowButton(ctx, "down_disabled", r.ImGui_Dir_Down())
                r.ImGui_PopStyleVar(ctx)
            end
            r.ImGui_TableSetColumnIndex(ctx, 1)
            local display_name = item.temp_name or item.display_name
            local is_selected = state.chain_selected_set[idx]
            if r.ImGui_Selectable(ctx, display_name, is_selected, 0) then
                local mods = r.ImGui_GetKeyMods(ctx)
                select_chain_item(idx, mods)
            end
            if r.ImGui_IsItemHovered(ctx) and r.ImGui_IsMouseDoubleClicked(ctx, 0) then
                state.chain_renaming_idx = idx - 1
                state.chain_rename_buffer = item.temp_name or item.display_name
                state.chain_rename_popup_open = true
                  state.popups_opened =   state.popups_opened + 1
            end
            if r.ImGui_BeginPopupContextItem(ctx) then
                if r.ImGui_Selectable(ctx, "Remove from Chain") then
                    local selected_indices = get_sorted_selected_chain_indices()
                    local to_remove = {}
                    for _, i in ipairs(selected_indices) do
                        to_remove[i] = true
                    end
                    if not to_remove[idx] then
                        to_remove[idx] = true
                    end
                    for i = #state.chain_plugins, 1, -1 do
                        if to_remove[i] then
                            table.remove(state.chain_plugins, i)
                        end
                    end
                    state.chain_selected_set = {}
                    if #state.chain_plugins == 0 then
                        state.current_view = "plugins"
                    end
                end
                if r.ImGui_Selectable(ctx, "Reset to Global") then
                    reset_selected_chain_pins()
                end
                if r.ImGui_Selectable(ctx, "Rename") then
                    state.chain_renaming_idx = idx - 1
                    state.chain_rename_buffer = item.temp_name or item.display_name
                    state.chain_rename_popup_open = true
                      state.popups_opened =   state.popups_opened + 1
                end
                r.ImGui_EndPopup(ctx)
            end
            r.ImGui_TableSetColumnIndex(ctx, 2)
            r.ImGui_PushID(ctx, "pins" .. idx)
            local pin_label
            if item.is_fxchain then
                pin_label = "CHAIN"
            else
                local mode, pin = get_item_pin_config(item)
                pin_label = (mode or pin) and format_pin_display(mode and { mode = mode } or pin) or "Global"
            end
            if r.ImGui_Selectable(ctx, pin_label, is_selected, 0) then
                local mods = r.ImGui_GetKeyMods(ctx)
                select_chain_item(idx, mods)
            end
            if r.ImGui_IsItemHovered(ctx) then
                if item.is_fxchain then
                    r.ImGui_BeginTooltip(ctx)
                    r.ImGui_PushTextWrapPos(ctx, 300)
                    r.ImGui_Text(ctx, "FX Chain – cannot be edited.\nDouble‑click does nothing.")
                    r.ImGui_PopTextWrapPos(ctx)
                    r.ImGui_EndTooltip(ctx)
                else
                    local mode, pin = get_item_pin_config(item)
                    if mode then
                        r.ImGui_BeginTooltip(ctx)
                        r.ImGui_PushTextWrapPos(ctx, 300)
                        r.ImGui_Text(ctx, "Mode: " .. mode)
                        r.ImGui_Text(ctx, "Double‑click to edit")
                        r.ImGui_PopTextWrapPos(ctx)
                        r.ImGui_EndTooltip(ctx)
                    elseif pin then
                        r.ImGui_BeginTooltip(ctx)
                        r.ImGui_PushTextWrapPos(ctx, 300)
                        r.ImGui_Text(ctx, string.format("In: %d/%d Out: %d/%d", pin.inL, pin.inR, pin.outL, pin.outR))
                        r.ImGui_Text(ctx, "Double‑click to edit")
                        r.ImGui_PopTextWrapPos(ctx)
                        r.ImGui_EndTooltip(ctx)
                    else
                        r.ImGui_BeginTooltip(ctx)
                        r.ImGui_PushTextWrapPos(ctx, 300)
                        r.ImGui_Text(ctx, "Global (will follow global mode)")
                        r.ImGui_Text(ctx, "Double‑click to set custom")
                        r.ImGui_PopTextWrapPos(ctx)
                        r.ImGui_EndTooltip(ctx)
                    end
                end
            end
            if not item.is_fxchain and r.ImGui_IsItemHovered(ctx) and r.ImGui_IsMouseDoubleClicked(ctx, 0) then
                state.editing_plugin_name = item.name
                state.editing_chain_idx = idx - 1
                local mode, pin = get_item_pin_config(item)
                if mode then
                    state.custom_pin_mode = mode
                    local preset = get_mode_preset(mode)
                    state.custom_pin_buffer = { inL = preset.inL, inR = preset.inR, outL = preset.outL, outR = preset.outR }
                    state.custom_pin_force_custom = false
                elseif pin then
                    state.custom_pin_mode = nil
                    state.custom_pin_buffer = {
                        inL = pin.inL,
                        inR = pin.inR,
                        outL = pin.outL,
                        outR = pin.outR
                    }
                    state.custom_pin_force_custom = true
                else
                    state.custom_pin_mode = nil
                    state.custom_pin_buffer = { inL = settings.pin_preset.inL, inR = settings.pin_preset.inR, outL = settings.pin_preset.outL, outR = settings.pin_preset.outR }
                    state.custom_pin_force_custom = false
                end
                state.custom_pin_popup_open = true
                  state.popups_opened =   state.popups_opened + 1
            end
            if r.ImGui_BeginPopupContextItem(ctx) then
                if r.ImGui_Selectable(ctx, "Remove from Chain") then
                    local selected_indices = get_sorted_selected_chain_indices()
                    local to_remove = {}
                    for _, i in ipairs(selected_indices) do
                        to_remove[i] = true
                    end
                    if not to_remove[idx] then
                        to_remove[idx] = true
                    end
                    for i = #state.chain_plugins, 1, -1 do
                        if to_remove[i] then
                            table.remove(state.chain_plugins, i)
                        end
                    end
                    state.chain_selected_set = {}
                    if #state.chain_plugins == 0 then
                        state.current_view = "plugins"
                    end
                end
                if r.ImGui_Selectable(ctx, "Reset to Global") then
                    reset_selected_chain_pins()
                end
                if r.ImGui_Selectable(ctx, "Rename") then
                    state.chain_renaming_idx = idx - 1
                    state.chain_rename_buffer = item.temp_name or item.display_name
                    state.chain_rename_popup_open = true
                      state.popups_opened =   state.popups_opened + 1
                end
                r.ImGui_EndPopup(ctx)
            end
            r.ImGui_PopID(ctx)
            r.ImGui_PopID(ctx)
        end
        r.ImGui_EndTable(ctx)
    end
end

-- draw folder column
local function draw_column2()
    r.ImGui_PushItemWidth(ctx, -1)
    local changed, newval = r.ImGui_InputText(ctx, "##col2search", state.column2_search)
    if changed then state.column2_search = newval end
    r.ImGui_PopItemWidth(ctx)
    r.ImGui_Separator(ctx)
    if r.ImGui_BeginChild(ctx, "col2_list") then
        local query = state.column2_search:lower()
        for _, node in ipairs(folder_tree) do
            if query == "" or plain_find(node.name:lower(), query) then
                r.ImGui_PushID(ctx, node.guid)
                local is_selected = (state.selected_folder_guid == node.guid)
                if r.ImGui_Selectable(ctx, node.name, is_selected) then
                    state.selected_folder_guid = node.guid
                    state.current_view = "plugins"
                    state.first_run = true
                    state.custom_select = false
                end
                if r.ImGui_BeginPopupContextItem(ctx) then
                    if r.ImGui_Selectable(ctx, "Set as Go‑to Folder") then
                        settings.go_to_folder_id = node.guid
                        save_table(SETTINGS_FILE, settings)
                    end
                    r.ImGui_EndPopup(ctx)
                end
                r.ImGui_PopID(ctx)
            end
        end
        r.ImGui_EndChild(ctx)
    end
end

local function folder_passes_tag_filter(plugin_name)
    if next(state.tag_filter) == nil then return true end
    local nt = notes_tags[plugin_name] or {}
    if not nt.tags then return false end
    for filter_tag in pairs(state.tag_filter) do
        for _, t in ipairs(nt.tags) do
            if t == filter_tag then return true end
        end
    end
    return false
end

local function count_selected()
    local count = 0
    for _ in pairs(state.selected_plugins) do count = count + 1 end
    return count
end

-- draw plugins list
local function draw_plugins_list()
    if state.first_run then
        r.ImGui_SetKeyboardFocusHere(ctx, 0)
    end

    -- Search input
    r.ImGui_PushItemWidth(ctx, (r.ImGui_GetWindowWidth(ctx) * 0.58))
    local changed, newval = r.ImGui_InputText(ctx, "##col3search", state.column3_search)
    if changed then state.column3_search = newval end
    r.ImGui_SameLine(ctx)

    -- Tag filter button
    local filter_active = next(state.tag_filter) ~= nil
    if filter_active then
        r.ImGui_PushStyleColor(ctx, r.ImGui_Col_Button(), 0xBB401ADF)
    end
    if r.ImGui_Button(ctx, "Tag Filter") then
        r.ImGui_OpenPopup(ctx, "TagFilterPopup")
    end
    if filter_active then
        r.ImGui_PopStyleColor(ctx)
    end
    r.ImGui_PopItemWidth(ctx)

    -- Tag filter popup
    if r.ImGui_BeginPopup(ctx, "TagFilterPopup") then
        r.ImGui_Text(ctx, "Filter by tag (check to include):")
        r.ImGui_Separator(ctx)
        local folder_tags = get_tags_in_folder(state.selected_folder_guid)
        for _, tag in ipairs(folder_tags) do
            local checked = state.tag_filter[tag] or false
            local clicked, new_checked = r.ImGui_Checkbox(ctx, tag, checked)
            if clicked then
                if new_checked then
                    state.tag_filter[tag] = true
                else
                    state.tag_filter[tag] = nil
                end
                invalidate_plugin_cache()   -- tag filter changed
            end
        end
        r.ImGui_Separator(ctx)
        if r.ImGui_Button(ctx, "Clear All") then
            state.tag_filter = {}
            invalidate_plugin_cache()
            r.ImGui_CloseCurrentPopup(ctx)
        end
        r.ImGui_SameLine(ctx)
        if r.ImGui_Button(ctx, "Close") then
            r.ImGui_CloseCurrentPopup(ctx)
        end
        r.ImGui_EndPopup(ctx)
    end

    -- Cache check
    local cache = state.plugin_cache
    local current_folder_guid = state.selected_folder_guid
    local current_query = state.column3_search
    local current_tag_hash = tag_filter_hash()
    local current_sort_col = settings.sort_column
    local current_sort_asc = settings.sort_ascending
    local current_notes_version = state.data_versions.notes_tags
    local current_renames_version = state.data_versions.temp_renames
    local current_folder_version = state.data_versions.folder_tree

    local need_recompute = not cache.valid
        or cache.folder_guid ~= current_folder_guid
        or cache.query ~= current_query
        or cache.tag_filter_hash ~= current_tag_hash
        or cache.sort_column ~= current_sort_col
        or cache.sort_ascending ~= current_sort_asc
        or cache.notes_version ~= current_notes_version
        or cache.renames_version ~= current_renames_version
        or cache.folder_version ~= current_folder_version

    if need_recompute then
        local folder = find_folder_node(current_folder_guid)
        local plugins = folder and folder.plugins or {}
        local filtered = {}
        local query_lower = current_query:lower()
        local tag_filter = state.tag_filter
        local has_tag_filter = next(tag_filter) ~= nil

        for _, p in ipairs(plugins) do
            -- Match search (use precomputed lower_name and compute lower_display on the fly)
            local display_name = get_clean_name(p)
            local lower_display = display_name:lower()
            local match_search = current_query == "" or
                plain_find(lower_display, query_lower) or
                plain_find(p.lower_name, query_lower)

            if not match_search then goto skip end

            -- Tag filter
            if has_tag_filter then
                local nt = notes_tags[p.name]
                local tags = nt and nt.tags
                local matched = false
                if tags then
                    for filter_tag in pairs(tag_filter) do
                        for _, t in ipairs(tags) do
                            if t == filter_tag then matched = true; break end
                        end
                        if matched then break end
                    end
                end
                if not matched then goto skip end
            end

            table.insert(filtered, p)
            ::skip::
        end

    -- Sort filtered list (safe against nil values)
    table.sort(filtered, function(a, b)
        local va, vb
        if current_sort_col == 0 then
            va = get_clean_name(a):lower()
            vb = get_clean_name(b):lower()
        elseif current_sort_col == 1 then
            va = a.type or ""
            vb = b.type or ""
        elseif current_sort_col == 2 then
            va = a.developer or ""
            vb = b.developer or ""
        elseif current_sort_col == 3 then
            local nta = notes_tags[a.name] or {}
            local ntb = notes_tags[b.name] or {}
            va = (nta.tags and table.concat(nta.tags, ", ")) or ""
            vb = (ntb.tags and table.concat(ntb.tags, ", ")) or ""
            va = va:lower()
            vb = vb:lower()
        else
            va = a.lower_name or ""
            vb = b.lower_name or ""
        end
        if current_sort_asc then
            return va < vb
        else
            return va > vb
        end
    end)

        -- Update cache
        cache.valid = true
        cache.folder_guid = current_folder_guid
        cache.query = current_query
        cache.tag_filter_hash = current_tag_hash
        cache.sort_column = current_sort_col
        cache.sort_ascending = current_sort_asc
        cache.notes_version = current_notes_version
        cache.renames_version = current_renames_version
        cache.folder_version = current_folder_version
        cache.list = filtered
    end

    local filtered = cache.list

    -- Auto‑select first plugin only when list changes
    if (state.first_run or need_recompute) then
        state.first_run = false
        if #filtered > 0 and not state.custom_select then
            state.selected_plugins = {}
            state.selected_plugins[filtered[1].name] = true
            state.last_clicked_index = 1
        end
    end

    -- Draw table
    local col_flags = r.ImGui_TableFlags_Resizable() | r.ImGui_TableFlags_Borders()
    if r.ImGui_BeginTable(ctx, "col3table", 5, col_flags) then
        r.ImGui_TableSetupColumn(ctx, "Type", r.ImGui_TableColumnFlags_WidthFixed() | r.ImGui_TableColumnFlags_NoResize(), 40)
        r.ImGui_TableSetupColumn(ctx, "Name", r.ImGui_TableColumnFlags_WidthFixed(), 150)
        r.ImGui_TableSetupColumn(ctx, "Developer", r.ImGui_TableColumnFlags_WidthFixed(), 100)
        r.ImGui_TableSetupColumn(ctx, "Tags", r.ImGui_TableColumnFlags_WidthFixed(), 120)
        r.ImGui_TableSetupColumn(ctx, "Pins", r.ImGui_TableColumnFlags_WidthStretch(), 80)
        r.ImGui_TableHeadersRow(ctx)

        for i, p in ipairs(filtered) do
            local nt = notes_tags[p.name] or {}
            local tags_str = nt.tags and table.concat(nt.tags, ", ") or ""
            local display_name = get_clean_name(p)

            r.ImGui_TableNextRow(ctx)

            -- Type column
            r.ImGui_TableSetColumnIndex(ctx, 0)
            r.ImGui_PushID(ctx, "type" .. i)
            if r.ImGui_Selectable(ctx, p.type, state.selected_plugins[p.name] or false) then
                local mods = r.ImGui_GetKeyMods(ctx)
                select_plugin(p.name, i, filtered, mods)
            end
            if r.ImGui_BeginPopupContextItem(ctx) then
                if r.ImGui_Selectable(ctx, "Sort Type Ascending") then
                    settings.sort_column = 1; settings.sort_ascending = true
                    invalidate_plugin_cache()
                end
                if r.ImGui_Selectable(ctx, "Sort Type Descending") then
                    settings.sort_column = 1; settings.sort_ascending = false
                    invalidate_plugin_cache()
                end
                r.ImGui_EndPopup(ctx)
            end
            r.ImGui_PopID(ctx)

            -- Name column
            r.ImGui_TableSetColumnIndex(ctx, 1)
            local selected = state.selected_plugins[p.name] or false
            if r.ImGui_Selectable(ctx, display_name, selected) then
                local mods = r.ImGui_GetKeyMods(ctx)
                select_plugin(p.name, i, filtered, mods)
            end
            if r.ImGui_BeginPopupContextItem(ctx) then
                if r.ImGui_Selectable(ctx, "Edit Note") then
                    state.editing_plugin_name = p.name
                    state.edit_buffer = nt.note or ""
                    state.note_edit_popup_open = true
                end
                if r.ImGui_Selectable(ctx, "Rename") then
                    state.renaming_plugin = p.name
                    state.rename_buffer = display_name
                    state.rename_popup_open = true
                end
                if state.temp_renames[p.name] ~= nil then
                    if r.ImGui_Selectable(ctx, "Reset Name") then
                        state.temp_renames[p.name] = nil
                        bump_temp_renames_version()
                    end
                end
                if r.ImGui_Selectable(ctx, "Sort Name Ascending") then
                    settings.sort_column = 0; settings.sort_ascending = true
                    invalidate_plugin_cache()
                end
                if r.ImGui_Selectable(ctx, "Sort Name Descending") then
                    settings.sort_column = 0; settings.sort_ascending = false
                    invalidate_plugin_cache()
                end
                if count_selected() > 0 then
                    if r.ImGui_Selectable(ctx, "Add selected to FX Chain") then
                        local chain = build_chain_from_selection()
                        add_to_chain(chain)
                    end
                end
                r.ImGui_EndPopup(ctx)
            end
            if r.ImGui_IsItemHovered(ctx) and r.ImGui_IsMouseDoubleClicked(ctx, 0) then
                state.renaming_plugin = p.name
                state.rename_buffer = display_name
                state.rename_popup_open = true
            end

            -- Developer column
            r.ImGui_TableSetColumnIndex(ctx, 2)
            r.ImGui_PushID(ctx, "dev" .. i)
            if r.ImGui_Selectable(ctx, p.developer, state.selected_plugins[p.name] or false) then
                local mods = r.ImGui_GetKeyMods(ctx)
                select_plugin(p.name, i, filtered, mods)
            end
            if r.ImGui_BeginPopupContextItem(ctx) then
                if r.ImGui_Selectable(ctx, "Sort Developer Ascending") then
                    settings.sort_column = 2; settings.sort_ascending = true
                    invalidate_plugin_cache()
                end
                if r.ImGui_Selectable(ctx, "Sort Developer Descending") then
                    settings.sort_column = 2; settings.sort_ascending = false
                    invalidate_plugin_cache()
                end
                r.ImGui_EndPopup(ctx)
            end
            r.ImGui_PopID(ctx)

            -- Tags column
            r.ImGui_TableSetColumnIndex(ctx, 3)
            r.ImGui_PushID(ctx, "tags" .. i)
            if r.ImGui_Selectable(ctx, tags_str, state.selected_plugins[p.name] or false) then
                local mods = r.ImGui_GetKeyMods(ctx)
                select_plugin(p.name, i, filtered, mods)
            end
            if r.ImGui_BeginPopupContextItem(ctx) then
                if r.ImGui_Selectable(ctx, "Edit Tags") then
                    state.editing_plugin_name = p.name
                    state.edit_buffer = tags_str
                    state.tag_edit_popup_open = true
                end
                if r.ImGui_Selectable(ctx, "Sort Tags Ascending") then
                    settings.sort_column = 3; settings.sort_ascending = true
                    invalidate_plugin_cache()
                end
                if r.ImGui_Selectable(ctx, "Sort Tags Descending") then
                    settings.sort_column = 3; settings.sort_ascending = false
                    invalidate_plugin_cache()
                end
                r.ImGui_EndPopup(ctx)
            end
            r.ImGui_PopID(ctx)
            if r.ImGui_IsItemHovered(ctx) and r.ImGui_IsMouseDoubleClicked(ctx, 0) then
                state.editing_plugin_name = p.name
                state.edit_buffer = tags_str
                state.tag_edit_popup_open = true
            end

            -- Pins column
            r.ImGui_TableSetColumnIndex(ctx, 4)
            r.ImGui_PushID(ctx, "pins" .. i)
            local pin_config = nt.pin
            local pin_label
            if p.is_fxchain then
                pin_label = "CHAIN"
            else
                pin_label = pin_config and format_pin_display(pin_config) or format_pin_display(nil)
            end
            if r.ImGui_Selectable(ctx, pin_label, state.selected_plugins[p.name] or false) then
                local mods = r.ImGui_GetKeyMods(ctx)
                select_plugin(p.name, i, filtered, mods)
            end
            if r.ImGui_IsItemHovered(ctx) then
                if p.is_fxchain then
                    r.ImGui_SetTooltip(ctx, "FX Chain – pins cannot be set.\nAdd to chain builder to include.")
                elseif pin_config then
                    if pin_config.mode then
                        r.ImGui_SetTooltip(ctx, string.format("Mode: %s\nDouble-click to edit", pin_config.mode))
                    else
                        r.ImGui_SetTooltip(ctx, string.format("In: %d/%d Out: %d/%d\nDouble-click to edit", pin_config.inL, pin_config.inR, pin_config.outL, pin_config.outR))
                    end
                else
                    r.ImGui_SetTooltip(ctx, "Global (will follow global mode)\ndouble-click to set custom")
                end
            end
            if not p.is_fxchain then
                if r.ImGui_BeginPopupContextItem(ctx) then
                    if r.ImGui_Selectable(ctx, "Set to Global") then
                        if notes_tags[p.name] then notes_tags[p.name].pin = nil end
                        save_table(NOTES_TAGS_FILE, notes_tags)
                        bump_notes_tags_version()
                    end
                    if r.ImGui_Selectable(ctx, "Set Selected to Global") then
                        for name in pairs(state.selected_plugins) do
                            if notes_tags[name] then notes_tags[name].pin = nil end
                        end
                        save_table(NOTES_TAGS_FILE, notes_tags)
                        bump_notes_tags_version()
                    end
                    r.ImGui_EndPopup(ctx)
                end
                if r.ImGui_IsItemHovered(ctx) and r.ImGui_IsMouseDoubleClicked(ctx, 0) then
                    state.editing_plugin_name = p.name
                    state.editing_chain_idx = nil
                    local pin_data = nt.pin
                    if pin_data and pin_data.mode then
                        state.custom_pin_mode = pin_data.mode
                        local preset = get_mode_preset(pin_data.mode)
                        state.custom_pin_buffer = { inL = preset.inL, inR = preset.inR, outL = preset.outL, outR = preset.outR }
                        state.custom_pin_force_custom = false
                    elseif pin_data and (pin_data.inL ~= nil) then
                        state.custom_pin_mode = nil
                        state.custom_pin_buffer = {
                            inL = pin_data.inL,
                            inR = pin_data.inR,
                            outL = pin_data.outL,
                            outR = pin_data.outR
                        }
                        state.custom_pin_force_custom = true
                    else
                        state.custom_pin_mode = nil
                        state.custom_pin_buffer = { inL = settings.pin_preset.inL, inR = settings.pin_preset.inR, outL = settings.pin_preset.outL, outR = settings.pin_preset.outR }
                        state.custom_pin_force_custom = false
                    end
                    state.custom_pin_popup_open = true
                end
            end
            r.ImGui_PopID(ctx)
        end
        r.ImGui_EndTable(ctx)
    end
end

-- status bar
local function draw_status_bar()
    if not settings.status_bar_height then settings.status_bar_height = 50 end
    local line_height = r.ImGui_GetTextLineHeightWithSpacing(ctx)
    local min_height = line_height + 8
    local max_height = 200
    r.ImGui_Separator(ctx)
    local sep_min_x, sep_min_y = r.ImGui_GetItemRectMin(ctx)
    local sep_max_x, sep_max_y = r.ImGui_GetItemRectMax(ctx)
    local drag_area_height = 6
    local drag_min_y = sep_min_y - drag_area_height/2
    local drag_max_y = sep_max_y + drag_area_height/2
    r.ImGui_SetCursorScreenPos(ctx, sep_min_x, drag_min_y)
    r.ImGui_InvisibleButton(ctx, "status_drag", sep_max_x - sep_min_x, drag_max_y - drag_min_y)
    local is_hovering = r.ImGui_IsItemHovered(ctx)
    if is_hovering then r.ImGui_SetMouseCursor(ctx, r.ImGui_MouseCursor_ResizeNS()) end
    if is_hovering and r.ImGui_IsMouseClicked(ctx, 0) and not state.resize_dragging then
        local mouse_x, mouse_y = r.ImGui_GetMousePos(ctx)
        state.resize_dragging = true
        state.resize_start_y = mouse_y
        state.resize_start_height = settings.status_bar_height
    end
    if state.resize_dragging and r.ImGui_IsMouseDown(ctx, 0) then
        local mouse_x, mouse_y = r.ImGui_GetMousePos(ctx)
        local delta = state.resize_start_y - mouse_y
        local new_height = state.resize_start_height + delta
        settings.status_bar_height = math.max(min_height, math.min(max_height, new_height))
        r.ImGui_SetMouseCursor(ctx, r.ImGui_MouseCursor_ResizeNS())
    elseif state.resize_dragging and not r.ImGui_IsMouseDown(ctx, 0) then
        state.resize_dragging = false
    end
    r.ImGui_PushStyleColor(ctx, r.ImGui_Col_ChildBg(), 0x40000000)
    if r.ImGui_BeginChild(ctx, "status_bar", 0, settings.status_bar_height, 0, 0) then
        local names = {}
        local count = 0
        if state.current_view == "plugins" then
            for name in pairs(state.selected_plugins) do
                names[#names + 1] = name
                count = count + 1
            end
        else
            for idx in pairs(state.chain_selected_set) do
                local item = state.chain_plugins[idx]
                if item then
                    names[#names + 1] = item.name
                    count = count + 1
                end
            end
        end
        if count == 1 then
            local name = names[1]
            local nt = notes_tags[name] or {}
            local note = nt.note or ""
            local display_note = note_to_display_string(note)
            local max_len = 200
            if #display_note > max_len then
                local short = display_note:sub(1, max_len) .. "…"
                r.ImGui_Text(ctx, short)
                r.ImGui_SameLine(ctx)
                if r.ImGui_Button(ctx, "View Full Note") then
                    state.full_note_plugin = name
                    state.full_note_text = note
                    state.full_note_popup_open = true
                      state.popups_opened =   state.popups_opened + 1
                end
            else
                if display_note == "" then
                    r.ImGui_Text(ctx, string.format("%s (no note)", name))
                else
                    local display = string.format("%s → %s", name, display_note)
                    local avail_w, avail_h = r.ImGui_GetContentRegionAvail(ctx)
                    r.ImGui_InvisibleButton(ctx, "status_selectable", avail_w, avail_h)
                    if r.ImGui_IsItemHovered(ctx) and r.ImGui_IsMouseDoubleClicked(ctx, 0) then
                        state.full_note_plugin = name
                        state.full_note_text = note
                        state.full_note_popup_open = true
                          state.popups_opened =   state.popups_opened + 1
                    end
                    r.ImGui_SetCursorPos(ctx, r.ImGui_GetCursorStartPos(ctx))
                    r.ImGui_TextWrapped(ctx, display)
                end
            end
        elseif count > 1 then
            local label = (state.current_view == "plugins") and "plugins" or "items"
            r.ImGui_Text(ctx, string.format("%d %s selected", count, label))
        else
            r.ImGui_Text(ctx, "No selection")
        end
        r.ImGui_EndChild(ctx)
    end
    r.ImGui_PopStyleColor(ctx)
end

-- ======================================================================
-- Shortcut handling
-- ======================================================================
local function check_shortcuts()
    if state.popups_opened > 0 then return end
    local mods = r.ImGui_GetKeyMods(ctx)
    if mods & r.ImGui_Mod_Ctrl() ~= 0 then
        if r.ImGui_IsKeyPressed(ctx, r.ImGui_Key_K()) then
            state.stay_open = not state.stay_open
        end
    end
    local shift_pressed = mods & r.ImGui_Mod_Shift() ~= 0
    if state.current_view == "chain" then
        if r.ImGui_IsKeyPressed(ctx, r.ImGui_Key_Enter()) then
            add_chain_to_track(state.chain_plugins, shift_pressed)
        end
        if mods & r.ImGui_Mod_Ctrl() ~= 0 and r.ImGui_IsKeyPressed(ctx, r.ImGui_Key_S()) then
            save_chain_as_fxchain()
        end
    else
        if r.ImGui_IsKeyPressed(ctx, r.ImGui_Key_Enter()) then
            local chain = build_chain_from_selection()
            if #chain > 0 then
                local target_type = state.insert_target
                if target_type == 1 then
                    if has_fxchain(chain) then
                        r.ShowMessageBox("Take insertion of FX chains is not yet supported. Please use track insertion.", "Not Supported", 0)
                    else
                        add_plugins_with_configs(chain, shift_pressed)
                    end
                else
                    if has_fxchain(chain) then
                        add_chain_to_track(chain, shift_pressed)
                    else
                        add_plugins_with_configs(chain, shift_pressed)
                    end
                end
            end
        end
    end
    if state.current_view == "chain" and next(state.chain_selected_set) then
        if r.ImGui_IsKeyPressed(ctx, r.ImGui_Key_Delete()) then
            remove_selected_chain_items()
        end
    end
    if mods & r.ImGui_Mod_Ctrl() ~= 0 and mods & r.ImGui_Mod_Shift() ~= 0 and
       r.ImGui_IsKeyPressed(ctx, r.ImGui_Key_C()) and state.current_view == "plugins" then
        local chain = build_chain_from_selection()
        if #chain > 0 then
            add_to_chain(chain)
            state.current_view = "chain"
        end
    end
    if mods & r.ImGui_Mod_Ctrl() ~= 0 and mods & r.ImGui_Mod_Shift() ~= 0 and
       r.ImGui_IsKeyPressed(ctx, r.ImGui_Key_X()) then
        if state.current_view == "plugins" and #state.chain_plugins > 0 then
            state.current_view = "chain"
        elseif state.current_view == "chain" then
            state.current_view = "plugins"
        end
    end
end

-- ======================================================================
-- Main loop
-- ======================================================================
local function loop()
    if not ctx or ctx == 0 then
        r.ShowConsoleMsg("ImGui context lost. Exiting.\n")
        return
    end
    r.ImGui_SetNextWindowSize(ctx, 900, 600, r.ImGui_Cond_FirstUseEver())
    local visible, open = r.ImGui_Begin(ctx, "ReaFX Folder", true)
    if visible then
        draw_header()
        r.ImGui_Separator(ctx)
        local current_y = r.ImGui_GetCursorPosY(ctx)
        local window_height = r.ImGui_GetWindowHeight(ctx)
        if not settings.status_bar_height then settings.status_bar_height = 50 end
        local status_height = settings.status_bar_height
        local table_height = window_height - (current_y + 20) - status_height
        if table_height < 100 then table_height = 100 end
        if r.ImGui_BeginChild(ctx, "MainTableRegion", 0, table_height) then
            if r.ImGui_BeginTable(ctx, "main_columns", 2, r.ImGui_TableFlags_Resizable()) then
                r.ImGui_TableSetupColumn(ctx, "Folders", r.ImGui_TableColumnFlags_WidthFixed() | r.ImGui_TableColumnFlags_NoResize(), 180)
                r.ImGui_TableSetupColumn(ctx, "Contents", r.ImGui_TableColumnFlags_WidthStretch(), 0)
                r.ImGui_TableHeadersRow(ctx)
                r.ImGui_TableNextColumn(ctx)
                draw_column2()
                r.ImGui_TableNextColumn(ctx)
                if state.current_view == "plugins" then
                    draw_plugins_list()
                else
                    draw_chain_list()
                end
                r.ImGui_EndTable(ctx)
            end
            r.ImGui_EndChild(ctx)
        end
        draw_chain_rename_popup()
        draw_rename_popup()
        draw_status_bar()
        draw_pin_popup()
        draw_note_popup()
        draw_tag_popup()
        draw_custom_pin_popup()
        draw_confirmation_popup()
        draw_full_note_popup()
        check_shortcuts()
        r.ImGui_End(ctx)
    end
    if open and not state.close_requested then
        r.defer(loop)
    else
        save_table(SETTINGS_FILE, settings)
        save_table(NOTES_TAGS_FILE, notes_tags)
        if r.ImGui_DestroyContext then
            r.ImGui_DestroyContext(ctx)
        end
    end
end

r.defer(loop)
