-- @description ReaFX Folder
-- @version 1.9
-- @author Resnard Lapiz (refactored with assistance)
-- @about Two-column browser for custom FX folders with per-plugin notes, tags, and intelligent pin routing.
--   New: temporary FX chain builder (Column 1) with reordering, independent pin configs, save to file.
--   Parses reaper-fxfolders.ini directly. Features: stay-open toggle, shift+enter bypass,
--   dynamic unused pair detection for SC modes, column sorting, tag filtering.
-- @noindex

local r = reaper

-- ======================================================================
-- Dependency check
-- ======================================================================
if not r.ImGui_CreateContext then
    r.ShowMessageBox("ReaImGui not found. Please install cfillion's ReaImGui.", "Missing dependency", 0)
    return
end

local ctx = r.ImGui_CreateContext("ReaFX Folder")
if not ctx then
    r.ShowMessageBox("Failed to create ImGui context.", "Error", 0)
    return
end

-- ======================================================================
-- Paths / storage
-- ======================================================================
local script_path = debug.getinfo(1, "S").source:match("^@?(.*[\\/])") or ""
local resource_path = r.GetResourcePath()
local sep = package.config:sub(1, 1)

local data_dir = script_path .. "ReaFX_Folder_Data"
r.RecursiveCreateDirectory(data_dir, 0)

local SETTINGS_FILE = data_dir .. sep .. "settings.lua"
local NOTES_TAGS_FILE = data_dir .. sep .. "notes_tags.lua"
local FXFOLDERS_INI = resource_path .. sep .. "reaper-fxfolders.ini"

-- ======================================================================
-- Small utilities
-- ======================================================================
local function clamp_channel(val)
    val = tonumber(val) or 1
    if val < 1 then return 1 end
    if val > 64 then return 64 end
    return val
end

local function plain_find(haystack, needle)
    if needle == "" then return true end
    if not haystack or not needle then return false end
    return haystack:find(needle, 1, true) ~= nil
end

local function pair_text(a, b) return string.format("%d/%d", a or 0, b or 0) end

local function split_csv(text)
    local out = {}
    text = text or ""
    for token in text:gmatch("[^,]+") do
        token = token:match("^%s*(.-)%s*$")
        if token ~= "" then out[#out + 1] = token end
    end
    return out
end

local function is_array(tbl)
    if type(tbl) ~= "table" then return false, 0 end
    local n = 0
    for k, _ in pairs(tbl) do
        if type(k) ~= "number" or k < 1 or k % 1 ~= 0 then return false, 0 end
        n = n + 1
    end
    for i = 1, n do if rawget(tbl, i) == nil then return false, 0 end end
    return true, n
end

local function sorted_keys(tbl)
    local keys = {}
    for k in pairs(tbl) do keys[#keys + 1] = k end
    table.sort(keys, function(a, b) return tostring(a) < tostring(b) end)
    return keys
end

local function serialize_value(v, indent)
    local t = type(v)
    if t == "table" then
        local array, n = is_array(v)
        local pad = string.rep(" ", indent)
        local child_pad = string.rep(" ", indent + 2)
        if array then
            local items = {}
            for i = 1, n do items[#items + 1] = child_pad .. serialize_value(v[i], indent + 2) end
            return "{\n" .. table.concat(items, ",\n") .. "\n" .. pad .. "}"
        end
        local items = {}
        for _, k in ipairs(sorted_keys(v)) do
            local key_repr
            if type(k) == "string" and k:match("^[%a_][%w_]*$") then
                key_repr = k
            else
                key_repr = "[" .. string.format("%q", k) .. "]"
            end
            items[#items + 1] = child_pad .. key_repr .. " = " .. serialize_value(v[k], indent + 2)
        end
        return "{\n" .. table.concat(items, ",\n") .. "\n" .. pad .. "}"
    elseif t == "string" then
        return string.format("%q", v)
    else
        return tostring(v)
    end
end

local function serialize(tbl) return serialize_value(tbl, 0) end

local function load_table(path, default)
    local f = io.open(path, "r")
    if not f then return default or {} end
    local content = f:read("*a")
    f:close()
    local fn = load("return " .. content, "load_table", "t", {})
    if not fn then return default or {} end
    local ok, res = pcall(fn)
    if not ok or type(res) ~= "table" then return default or {} end
    return res
end

local function save_table(path, tbl)
    local f = io.open(path, "w")
    if not f then return false end
    f:write(serialize(tbl))
    f:close()
    return true
end

local function set_style_button_transparent()
    r.ImGui_PushStyleColor(ctx, r.ImGui_Col_Button(), 0x00000000)
end

-- ======================================================================
-- Pin mode definitions
-- ======================================================================
local MODE_NAMES = {
    "Default", "SC→SC", "In→SC", "SC→Out", "In→Left", "In→Right",
    "SC→Left", "SC→Right", "Left→Out", "Right→Out", "Left→SC", "Right→SC", "Custom"
}

local MODE_PRESETS = {
    ["Default"]   = { inL = 1, inR = 2, outL = 1, outR = 2 },
    ["SC→SC"]     = { inL = 3, inR = 4, outL = 3, outR = 4 },
    ["In→SC"]     = { inL = 1, inR = 2, outL = 3, outR = 4 },
    ["SC→Out"]    = { inL = 3, inR = 4, outL = 1, outR = 2 },
    ["In→Left"]   = { inL = 1, inR = 2, outL = 1, outR = 1 },
    ["In→Right"]  = { inL = 1, inR = 2, outL = 2, outR = 2 },
    ["SC→Left"]   = { inL = 3, inR = 4, outL = 1, outR = 1 },
    ["SC→Right"]  = { inL = 3, inR = 4, outL = 2, outR = 2 },
    ["Left→Out"]  = { inL = 1, inR = 1, outL = 1, outR = 2 },
    ["Right→Out"] = { inL = 2, inR = 2, outL = 1, outR = 2 },
    ["Left→SC"]   = { inL = 1, inR = 1, outL = 3, outR = 4 },
    ["Right→SC"]  = { inL = 2, inR = 2, outL = 3, outR = 4 },
}

local MODE_DESCRIPTIONS = {
    ["Default"]   = "Default: Input and output both use channels 1/2.",
    ["SC→SC"]     = "SC→SC: Input and output both use the same unused stereo pair (auto).",
    ["In→SC"]     = "In→SC: Input uses 1/2, output uses an unused stereo pair (auto).",
    ["SC→Out"]    = "SC→Out: Input uses an unused stereo pair (auto), output uses 1/2.",
    ["In→Left"]   = "In→Left: Input uses 1/2, output sends left only to channel 1.",
    ["In→Right"]  = "In→Right: Input uses 1/2, output sends right only to channel 2.",
    ["SC→Left"]   = "SC→Left: Input uses an unused stereo pair (auto), output sends left only to channel 1.",
    ["SC→Right"]  = "SC→Right: Input uses an unused stereo pair (auto), output sends right only to channel 2.",
    ["Left→Out"]  = "Left→Out: Input takes left only from channel 1, output sends to 1/2.",
    ["Right→Out"] = "Right→Out: Input takes right only from channel 2, output sends to 1/2.",
    ["Left→SC"]   = "Left→SC: Input takes left only from channel 1, output uses an unused stereo pair (auto).",
    ["Right→SC"]  = "Right→SC: Input takes right only from channel 2, output uses an unused stereo pair (auto).",
    ["Custom"]    = "Custom: Manually set all four track channels.",
}

local function get_mode_preset(mode)
    local p = MODE_PRESETS[mode]
    if not p then return { inL = 1, inR = 2, outL = 1, outR = 2 } end
    return { inL = p.inL, inR = p.inR, outL = p.outL, outR = p.outR }
end

local function get_mode_description(mode) return MODE_DESCRIPTIONS[mode] or "" end

local function get_global_pin_text(mode, p)
    p = p or get_mode_preset(mode)
    if mode == "SC→SC" then
        return "auto", "auto"
    elseif mode == "In→SC" then
        return pair_text(p.inL, p.inR), "auto"
    elseif mode == "SC→Out" then
        return "auto", pair_text(p.outL, p.outR)
    elseif mode == "SC→Left" or mode == "SC→Right" then
        return "auto", pair_text(p.outL, p.outR)
    elseif mode == "Left→SC" or mode == "Right→SC" then
        return pair_text(p.inL, p.inR), "auto"
    elseif mode == "Default" or mode == "In→Left" or mode == "In→Right" or mode == "Left→Out" or mode == "Right→Out" or mode == "Custom" then
        return pair_text(p.inL, p.inR), pair_text(p.outL, p.outR)
    end
    return "?", "?"
end

-- ======================================================================
-- Smart folder parsing
-- ======================================================================
local function parse_fx_folders()
    local plugin_list = {}
    local idx = 0
    while true do
        local ok, name = r.EnumInstalledFX(idx)
        if not ok then break end
        plugin_list[#plugin_list + 1] = name
        idx = idx + 1
    end
    plugin_list[#plugin_list + 1] = "Container"
    plugin_list[#plugin_list + 1] = "Video processor"

    local magic = {
        ["not"] = { " and ", " not %s:find(%q, 1, true) " },
        ["or"]  = { " or ", " %s:find(%q, 1, true) " },
        ["and"] = { " and ", "%s:find(%q, 1, true) " },
    }
    local function parse_smart_folder(smart_string)
        smart_string = tostring(smart_string or "")
    
        local console = (r and r.ShowConsoleMsg) or (reaper and reaper.ShowConsoleMsg)
        local function log(msg)
            if console then console(msg) end
        end
    
        if type(plugin_list) ~= "table" then
            log("Smart folder error: plugin_list is missing or invalid\n")
            return {}
        end
    
        -- Tokeniser (byte comparisons, lowercase normalization)
        local tokens = {}
        local pos = 1
        local len = #smart_string
    
        while pos <= len do
            local b = smart_string:byte(pos)
    
            if b == 32 or b == 9 then
                pos = pos + 1
    
            elseif b == 40 then -- '('
                tokens[#tokens + 1] = "("
                pos = pos + 1
    
            elseif b == 41 then -- ')'
                tokens[#tokens + 1] = ")"
                pos = pos + 1
    
            elseif b == 34 then -- '"'
                local start = pos + 1
                local qpos = start
                local found = false
    
                while qpos <= len do
                    local qb = smart_string:byte(qpos)
                    if qb == 34 and smart_string:byte(qpos - 1) ~= 92 then
                        found = true
                        break
                    end
                    qpos = qpos + 1
                end
    
                local phrase = smart_string:sub(start, found and (qpos - 1) or len):lower()
                tokens[#tokens + 1] = phrase
    
                if found then
                    pos = qpos + 1
                else
                    log("Smart folder warning: unterminated quote; using rest of line\n")
                    pos = len + 1
                end
    
            else
                local start = pos
                while pos <= len do
                    local c = smart_string:byte(pos)
                    if c == 32 or c == 9 or c == 40 or c == 41 then
                        break
                    end
                    pos = pos + 1
                end
    
                tokens[#tokens + 1] = smart_string:sub(start, pos - 1):lower()
            end
        end
    
        if #tokens == 0 then
            return {}
        end
    
        -- Build a dense plugin list so gaps in plugin_list cannot break matching
        local plugin_indices = {}
        local lower_plugins = {}
    
        for i, name in ipairs(plugin_list) do
            if type(name) == "string" then
                local dense_i = #plugin_indices + 1
                plugin_indices[dense_i] = i
                lower_plugins[dense_i] = name:lower()
            end
        end
    
        local plugin_count = #lower_plugins
        if plugin_count == 0 then
            return {}
        end
    
        -- Cache term matches: term -> boolean array
        local term_cache = {}
    
        local function clone_false_array()
            local arr = {}
            for i = 1, plugin_count do
                arr[i] = false
            end
            return arr
        end
    
        local function and_arrays(a, b)
            for i = 1, plugin_count do
                a[i] = a[i] and b[i]
            end
            return a
        end
        
        local function or_arrays(a, b)
            for i = 1, plugin_count do
                a[i] = a[i] or b[i]
            end
            return a
        end
        
        local function not_array(a)
            for i = 1, plugin_count do
                a[i] = not a[i]
            end
            return a
        end
    
        local function get_term_array(term)
            local cached = term_cache[term]
            if cached then
                return cached
            end
    
            local arr = {}
            for i = 1, plugin_count do
                local str = lower_plugins[i]
                arr[i] = (str ~= nil) and (str:find(term, 1, true) ~= nil) or false
            end
    
            term_cache[term] = arr
            return arr
        end
    
        -- Recursive descent parser
        local idx = 1
        local function peek() return tokens[idx] end
        local function consume()
            local t = tokens[idx]
            idx = idx + 1
            return t
        end
    
        local parse_expression
    
        local function is_primary_start(tok)
            return tok and tok ~= "and" and tok ~= "or" and tok ~= ")"
        end
    
        local function parse_primary()
            local token = peek()
    
            if not token then
                return nil, "unexpected end of expression"
            end
    
            if token == "not" then
                consume()
                local arr, err = parse_primary()
                if not arr then return nil, err end
                return not_array(arr)
    
            elseif token == "(" then
                consume()
                local arr, err = parse_expression()
                if not arr then return nil, err end
    
                if peek() ~= ")" then
                    return nil, "missing ')'"
                end
    
                consume()
                return arr
    
            elseif token == "and" or token == "or" then
                return nil, "unexpected operator '" .. token .. "'"
    
            else
                consume()
                return get_term_array(token)
            end
        end
    
        local function parse_and()
            local left, err = parse_primary()
            if not left then return nil, err end
    
            while true do
                local op = peek()
                if not op then
                    break
                end
    
                if op == "and" then
                    consume()
                    local right, err = parse_primary()
                    if not right then return nil, err end
                    left = and_arrays(left, right)
    
                elseif op == "not" then
                    -- Keep your existing shorthand:
                    -- A NOT B  -> A AND NOT B
                    consume()
                    local right, err = parse_primary()
                    if not right then return nil, err end
                    left = and_arrays(left, not_array(right))
    
                elseif is_primary_start(op) then
                    -- Implicit AND:
                    -- comp limiter  -> comp AND limiter
                    local right, err = parse_primary()
                    if not right then return nil, err end
                    left = and_arrays(left, right)
    
                else
                    break
                end
            end
    
            return left
        end
    
        local function parse_or()
            local left, err = parse_and()
            if not left then return nil, err end
    
            while true do
                local op = peek()
                if not op then
                    break
                end
    
                if op == "or" then
                    consume()
                    local right, err = parse_and()
                    if not right then return nil, err end
                    left = or_arrays(left, right)
                else
                    break
                end
            end
    
            return left
        end
    
        parse_expression = function()
            return parse_or()
        end
    
        local result_array, err = parse_expression()
        if not result_array then
            log("Smart folder parse error: " .. err .. "\n")
            return {}
        end
    
        if idx <= #tokens then
            local remaining = {}
            for i = idx, #tokens do
                remaining[#remaining + 1] = tokens[i]
            end
            log("Smart folder parse warning: extra tokens ignored: " .. table.concat(remaining, " ") .. "\n")
        end
    
        -- Collect matching plugins
        local smart_fx = {}
        for i = 1, plugin_count do
            if result_array[i] then
                local original_idx = plugin_indices[i]
                local name = plugin_list[original_idx]
                if type(name) == "string" then
                    smart_fx[#smart_fx + 1] = name
                end
            end
        end
    
        return smart_fx
    end

    local f = io.open(FXFOLDERS_INI, "r")
    if not f then return {} end

    local folders_by_idx = {}
    local folder_names = {}
    local folder_order = {}
    local current_folder_idx = nil
    local temp_items = {}

    for line in f:lines() do
        line = line:gsub("%s+$", "")
        if line:match("^%[") then
            local section = line:match("^%[(.-)%]$")
            if section and section:match("^Folder(%d+)$") then
                current_folder_idx = section:match("^Folder(%d+)$")
                folders_by_idx[current_folder_idx] = folders_by_idx[current_folder_idx] or { items = {} }
                temp_items[current_folder_idx] = temp_items[current_folder_idx] or {}
            elseif section == "Folders" then
                current_folder_idx = nil
            else
                current_folder_idx = nil
            end
        elseif current_folder_idx then
            local key, val = line:match("^(.-)=(.*)$")
            if key then
                if key:match("^Item%d+$") then
                    local idx = tonumber(key:match("^Item(%d+)$"))
                    if idx then
                        temp_items[current_folder_idx][idx] = temp_items[current_folder_idx][idx] or {}
                        temp_items[current_folder_idx][idx].query = val
                    end
                elseif key:match("^Type%d+$") then
                    local idx = tonumber(key:match("^Type(%d+)$"))
                    if idx then
                        temp_items[current_folder_idx][idx] = temp_items[current_folder_idx][idx] or {}
                        temp_items[current_folder_idx][idx].type = tonumber(val)
                    end
                elseif key == "parent" then
                    folders_by_idx[current_folder_idx].parent_guid = val
                end
            end
        else
            local id_str, name = line:match("^Name(%d+)=(.*)$")
            if id_str then
                folder_names[id_str] = name
                folder_order[#folder_order + 1] = id_str
                folders_by_idx[id_str] = folders_by_idx[id_str] or { items = {} }
                folders_by_idx[id_str].name = name
            end
        end
    end
    f:close()

    for idx, items_tbl in pairs(temp_items) do
        local items_list = {}
        local indices = {}
        for k in pairs(items_tbl) do indices[#indices + 1] = k end
        table.sort(indices)
        for _, i in ipairs(indices) do
            items_list[#items_list + 1] = {
                query = items_tbl[i].query,
                type = items_tbl[i].type
            }
        end
        folders_by_idx[idx].items = items_list
    end

    local folder_tree = {}
    for _, id_str in ipairs(folder_order) do
        local name = folder_names[id_str]
        local data = folders_by_idx[id_str]
        if data and data.items and #data.items > 0 then
            local all_plugins_with_meta = {}
            for _, item in ipairs(data.items) do
                local item_query = item.query
                local item_type = item.type
                local plugin_names
                if item_type == 1048576 then
                    plugin_names = parse_smart_folder(item_query)
                elseif item_type == 1000 then
                    plugin_names = { "CHAIN: " .. item_query:gsub('"', '') }
                else
                    plugin_names = { item_query:gsub('"', '') }
                end
                for _, pname in ipairs(plugin_names) do
                    local ptype = "Unknown"
                    if pname:match("^VST3:") then ptype = "VST3"
                    elseif pname:match("^VST:") then ptype = "VST2"
                    elseif pname:match("^VSTi:") then ptype = "VSTi"
                    elseif pname:match("^JS:") then ptype = "JS"
                    elseif pname:match("^CLAP") then ptype = "CLAP"
                    elseif pname:match("^AU") then ptype = "AU"
                    elseif pname:match("^LV2") then ptype = "LV2"
                    end
                    local developer = "Unknown"
                    local dev_match = pname:match("%(([^()]*)%)$")
                    if dev_match then developer = dev_match:match("^%s*(.-)%s*$") end
                    local is_fxchain = false
                    local chain_path = nil
                    if item_type == 1000 then
                        is_fxchain = true
                        local base = pname:gsub("^CHAIN: ", "")
                        chain_path = resource_path .. sep .. "FXChains" .. sep .. base .. ".RfxChain"
                        ptype = "CHAIN"
                        developer = "FX Chain"
                    end
                    table.insert(all_plugins_with_meta, {
                        name = pname,
                        type = ptype,
                        developer = developer,
                        is_fxchain = is_fxchain,
                        chain_path = chain_path,
                    })
                end
            end
            table.sort(all_plugins_with_meta, function(a, b) return a.name:lower() < b.name:lower() end)
            table.insert(folder_tree, {
                guid = id_str,
                name = name,
                plugins = all_plugins_with_meta,
            })
        end
    end
    table.sort(folder_tree, function(a, b) return a.name:lower() < b.name:lower() end)
    return folder_tree
end

-- ======================================================================
-- Persistent state
-- ======================================================================
local settings = {
    go_to_folder_id = nil,
    pin_mode = "Default",
    pin_preset = { inL = 1, inR = 2, outL = 1, outR = 2 },
    sort_column = 0,
    sort_ascending = true,
    status_bar_height = 50,
    insert_target = 0,
}
local notes_tags = {}

settings = load_table(SETTINGS_FILE, settings)
notes_tags = load_table(NOTES_TAGS_FILE, {})

if type(settings.pin_preset) ~= "table" then
    settings.pin_preset = get_mode_preset(settings.pin_mode)
else
    settings.pin_preset = {
        inL = clamp_channel(settings.pin_preset.inL or 1),
        inR = clamp_channel(settings.pin_preset.inR or 2),
        outL = clamp_channel(settings.pin_preset.outL or 1),
        outR = clamp_channel(settings.pin_preset.outR or 2),
    }
end

